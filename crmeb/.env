APP_DEBUG = true

[DATABASE]
TYPE = mysql
HOSTNAME = crmeb_mysql
HOSTPORT = 3306
DATABASE = crmeb
USERNAME = crmeb
PASSWORD = 123456
PREFIX = eb_
CHARSET = utf8mb4
COLLATION = utf8mb4_general_ci

[REDIS]
REDIS_HOSTNAME = crmeb_redis
PORT = 6379
REDIS_PASSWORD = 123456
SELECT = 0

[QUEUE]
QUEUE_NAME = CRMEB

[SYSTEM]
ADMIN_PREFIX = admin
DEFAULT_TIMEZONE = Asia/Shanghai
