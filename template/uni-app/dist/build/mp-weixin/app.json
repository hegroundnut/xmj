{
  "pages": [
    "pages/home/index",
    "pages/case/index",
    "pages/moment/index",
    "pages/moment/detail",
    "pages/moment/publish",
    "pages/teaching/index",
    "pages/my/index",
    "pages/my/favorites",
    "pages/my/courses",
    "pages/my/bookings",
    "pages/my/comments",
    "pages/my/posts",
    "pages/guide/index"
  ],
  "subPackages": [
    {
      "root": "pages/users",
      "pages": [
        "wechat_login/index",
        "binding_phone/index",
        "login/index",
        "privacy/index"
      ],
      "name": "users"
    }
  ],
  "window": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "洗眉机",
    "navigationBarBackgroundColor": "#fff",
    "backgroundColor": "#F8F8F8",
    "pageOrientation": "portrait"
  },
  "tabBar": {
    "color": "#282828",
    "selectedColor": "#e93323",
    "borderStyle": "white",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/index",
        "iconPath": "static/images/1-001.png",
        "selectedIconPath": "static/images/1-002.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/case/index",
        "iconPath": "static/images/2-001.png",
        "selectedIconPath": "static/images/2-002.png",
        "text": "案例"
      },
      {
        "pagePath": "pages/moment/index",
        "iconPath": "static/images/3-001.png",
        "selectedIconPath": "static/images/3-002.png",
        "text": "朋友圈"
      },
      {
        "pagePath": "pages/teaching/index",
        "iconPath": "static/images/4-001.png",
        "selectedIconPath": "static/images/4-002.png",
        "text": "教学"
      },
      {
        "pagePath": "pages/my/index",
        "iconPath": "static/images/5-001.png",
        "selectedIconPath": "static/images/5-002.png",
        "text": "我的"
      }
    ]
  },
  "preloadRule": {
    "pages/home/index": {
      "network": "all",
      "packages": [
        "users"
      ]
    }
  },
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于查看与门店的距离"
    }
  },
  "lazyCodeLoading": "requiredComponents",
  "requiredPrivateInfos": [
    "getLocation",
    "onLocationChange",
    "startLocationUpdateBackground",
    "chooseAddress"
  ],
  "__usePrivacyCheck__": true,
  "usingComponents": {
    "skeleton": "/components/skeleton/index",
    "page-loading": "/components/pageLoading",
    "easy-loadimage": "/components/easy-loadimage/easy-loadimage",
    "base-money": "/components/BaseMoney",
    "base-tag": "/components/BaseTag",
    "base-drawer": "/components/tuiDrawer/tui-drawer"
  }
}