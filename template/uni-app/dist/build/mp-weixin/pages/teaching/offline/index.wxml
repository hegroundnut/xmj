<view class="offline-page data-v-37b58745"><block wx:for="{{list}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['handleDetail',['$0'],[[['list','id',item.id]]]]]]]}}" class="class-item data-v-37b58745" bindtap="__e"><view class="class-header data-v-37b58745"><text class="class-title data-v-37b58745">{{item.title}}</text><text class="class-date data-v-37b58745">{{item.class_date}}</text></view><view class="class-info data-v-37b58745"><block wx:if="{{item.start_time}}"><text class="data-v-37b58745">{{"时间: "+item.start_time+" - "+item.end_time}}</text></block><text class="data-v-37b58745">{{"地点: "+item.address}}</text><block wx:if="{{item.max_people>0}}"><text class="data-v-37b58745">{{'剩余名额: '+(item.max_people-(item.booked_count||0))+" / "+item.max_people+''}}</text></block><block wx:else><text class="data-v-37b58745">{{"不限名额 (已约 "+(item.booked_count||0)+" 人)"}}</text></block></view><button data-event-opts="{{[['tap',[['handleBook',['$0'],[[['list','id',item.id]]]]]]]}}" class="book-btn data-v-37b58745" catchtap="__e">预约</button></view></block><view class="load-more-text data-v-37b58745">{{loadStatus==="noMore"?"没有更多了":loadStatus==="loading"?"加载中...":"上拉加载更多"}}</view><block wx:if="{{showBookForm}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="popup-overlay data-v-37b58745" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="popup-content data-v-37b58745" catchtap="__e"><text class="form-title data-v-37b58745">填写预约信息</text><input class="form-input data-v-37b58745" placeholder="姓名" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['bookForm']]]]]}}" value="{{bookForm.name}}" bindinput="__e"/><input class="form-input data-v-37b58745" placeholder="手机号" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['bookForm']]]]]}}" value="{{bookForm.phone}}" bindinput="__e"/><button class="submit-btn data-v-37b58745" loading="{{submitting}}" data-event-opts="{{[['tap',[['submitBook',['$event']]]]]}}" bindtap="__e">确认预约</button><text data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="close-btn data-v-37b58745" bindtap="__e">取消</text></view></view></block><block wx:if="{{showQrcode}}"><view data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" class="popup-overlay data-v-37b58745" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="popup-content data-v-37b58745" catchtap="__e"><text class="qrcode-title data-v-37b58745">请添加店主微信确认预约</text><image class="qrcode-img data-v-37b58745" src="{{qrcodeUrl}}" mode="widthFix"></image><button data-event-opts="{{[['tap',[['e3',['$event']]]]]}}" class="close-qr-btn data-v-37b58745" bindtap="__e">关闭</button></view></view></block></view>