<view class="product-page data-v-458804ed"><view class="custom-nav data-v-458804ed" style="{{'padding-top:'+(statusBarHeight+'px')+';'}}"><view class="nav-content data-v-458804ed"><text class="nav-title data-v-458804ed">产品展示</text></view></view><block wx:if="{{$root.g0}}"><swiper class="banner data-v-458804ed" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" indicator-active-color="#e93323"><block wx:for="{{info.banner}}" wx:for-item="url" wx:for-index="i" wx:key="i"><swiper-item data-event-opts="{{[['tap',[['previewBanner',[i]]]]]}}" bindtap="__e" class="data-v-458804ed"><image class="banner-img data-v-458804ed" src="{{url}}" mode="aspectFill"></image></swiper-item></block></swiper></block><view class="info-card data-v-458804ed"><text class="product-title data-v-458804ed">{{info.title||'洗眉机'}}</text><text class="product-desc data-v-458804ed">{{info.desc}}</text></view><block wx:if="{{$root.g1}}"><view class="specs-card data-v-458804ed"><view class="card-header data-v-458804ed"><text class="card-title data-v-458804ed">参数规格</text></view><block wx:for="{{info.specs}}" wx:for-item="item" wx:for-index="i" wx:key="i"><view class="spec-item data-v-458804ed"><text class="spec-key data-v-458804ed">{{item.key||item.name}}</text><text class="spec-value data-v-458804ed">{{item.value}}</text></view></block></view></block><block wx:if="{{info.video_url}}"><view class="video-card data-v-458804ed"><view class="card-header data-v-458804ed"><text class="card-title data-v-458804ed">产品视频</text></view><video class="product-video data-v-458804ed" src="{{info.video_url}}" controls="{{true}}" show-play-btn="{{true}}"></video></view></block><block wx:if="{{info.detail}}"><view class="detail-card data-v-458804ed"><view class="card-header data-v-458804ed"><text class="card-title data-v-458804ed">详细介绍</text></view><rich-text class="detail-content data-v-458804ed" nodes="{{info.detail}}"></rich-text></view></block><view class="bottom-bar data-v-458804ed"><view data-event-opts="{{[['tap',[['handleConsult',['$event']]]]]}}" class="consult-btn data-v-458804ed" bindtap="__e"><text class="data-v-458804ed">立即咨询</text></view></view></view>