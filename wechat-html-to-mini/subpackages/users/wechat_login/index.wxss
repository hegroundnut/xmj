/* ===== Full screen login page ===== */
.login-page { width: 100%; height: 100vh; position: relative; overflow: hidden; background: #1A1A1A; }

/* ===== Carousel ===== */
.carousel { position: absolute; inset: 0; width: 100%; height: 100%; }
.slide-img { width: 100%; height: 100%; }
.slide-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.25); }

/* ===== Slide text ===== */
.slide-text { position: absolute; left: 56rpx; right: 56rpx; z-index: 8; }
.slide-text.top-text { top: 180rpx; }
.slide-text.center-text { top: 50%; transform: translateY(-50%); }

.slide-number { font-size: 144rpx; font-weight: 200; color: rgba(255,255,255,0.7); line-height: 1; margin-bottom: 8rpx; display: block; font-family: "Helvetica Neue", sans-serif; }
.slide-label { font-size: 22rpx; letter-spacing: 12rpx; color: rgba(255,255,255,0.45); text-transform: uppercase; font-weight: 400; display: block; }
.slide-big-text { font-size: 88rpx; font-weight: 700; color: #fff; line-height: 1.15; letter-spacing: 8rpx; text-shadow: 0 4rpx 40rpx rgba(0,0,0,0.2); display: block; }
.en-mix { font-size: 28rpx; font-weight: 400; letter-spacing: 6rpx; color: rgba(255,255,255,0.6); display: block; margin-top: 16rpx; text-transform: uppercase; }

/* ===== Top/bottom gradients ===== */
.top-gradient { position: absolute; top: 0; left: 0; right: 0; height: 240rpx; background: linear-gradient(rgba(0,0,0,0.25), transparent); z-index: 6; pointer-events: none; }
.bottom-gradient { position: absolute; bottom: 0; left: 0; right: 0; height: 640rpx; background: linear-gradient(transparent, rgba(0,0,0,0.5)); z-index: 6; pointer-events: none; }

/* ===== Custom dots ===== */
.carousel-dots { position: absolute; top: 150rpx; left: 50%; transform: translateX(-50%); display: flex; gap: 16rpx; z-index: 15; }
.carousel-dots .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: rgba(255,255,255,0.3); transition: all 0.3s ease; }
.carousel-dots .dot.active { background: rgba(255,255,255,0.9); width: 36rpx; border-radius: 6rpx; }

/* ===== Bottom section ===== */
.bottom-section { position: absolute; bottom: 0; left: 0; right: 0; z-index: 15; padding: 0 56rpx 100rpx; }

.brand-strip { display: flex; align-items: center; gap: 20rpx; margin-bottom: 48rpx; }
.brand-logo-cn { font-size: 36rpx; font-weight: 700; color: #fff; letter-spacing: 8rpx; text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.2); display: block; }
.brand-logo-en { font-size: 20rpx; letter-spacing: 6rpx; color: rgba(255,255,255,0.5); font-weight: 400; text-transform: uppercase; display: block; margin-top: 6rpx; }

/* ===== Login button ===== */
.login-btn { width: 100%; height: 100rpx; line-height: 100rpx; background: #1A1A1A; color: #fff; border: none; border-radius: 60rpx; font-size: 28rpx; font-weight: 400; letter-spacing: 6rpx; margin-bottom: 20rpx; position: relative; overflow: hidden; }
.login-btn::after { border: none; }
.login-btn:active { transform: scale(0.98); }

/* ===== Agreement ===== */
.agreement { display: flex; align-items: flex-start; gap: 16rpx; justify-content: center; }
.checkbox { width: 28rpx; height: 28rpx; border: 3rpx solid rgba(255,255,255,0.35); border-radius: 6rpx; flex-shrink: 0; margin-top: 2rpx; display: flex; align-items: center; justify-content: center; }
.checkbox.checked { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.5); }
.check-mark { font-size: 20rpx; color: rgba(255,255,255,0.8); line-height: 1; }
.agreement-text { font-size: 20rpx; color: rgba(255,255,255,0.45); line-height: 1.5; font-weight: 300; }
.link { color: rgba(255,255,255,0.7); }
