.nav-icons { display: flex; flex-wrap: wrap; background: #fff; padding: 20rpx 0; margin: 12rpx 20rpx; border-radius: 12rpx; }
.nav-icon-item { width: 25%; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0; }
