<view class="product-detail-page">
  <navbar title="产品详情" back="{{true}}" transparent="{{true}}"/>

  <loading wx:if="{{loading}}" show="{{loading}}"/>
  <view wx:elif="{{error}}" class="error-box" bindtap="loadData">加载失败，点击重试</view>
  <empty wx:elif="{{!product}}" text="产品不存在"/>

  <block wx:else>
    <!-- Hero swiper -->
    <view class="product-hero">
      <swiper wx:if="{{product.images && product.images.length}}" bindchange="onSwiperChange" indicator-dots="{{false}}" class="hero-swiper">
        <swiper-item wx:for="{{product.images}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" class="hero-slide-img" bindtap="onPreviewImage"/>
        </swiper-item>
      </swiper>
      <view wx:else class="hero-placeholder"/>
      <view class="badge-row" wx:if="{{product.tags && product.tags.length}}">
        <text class="badge {{item.hot ? 'hot' : ''}}" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="img-counter" wx:if="{{product.images && product.images.length}}">{{currentSlide + 1}} / {{product.images.length}}</text>
    </view>

    <!-- Detail panel -->
    <view class="detail-panel">
      <view class="panel-handle"/>

      <!-- Product header -->
      <view class="prod-header">
        <text class="brand" wx:if="{{product.brand}}">{{product.brand}}</text>
        <text class="pname">{{product.name || product.title}}</text>
        <text class="en-name" wx:if="{{product.en_name}}">{{product.en_name}}</text>
        <text class="pdesc">{{product.description || product.desc}}</text>
      </view>

      <!-- Spec chips -->
      <view class="spec-chips" wx:if="{{product.specs && product.specs.length}}">
        <view class="spec-chip" wx:for="{{product.specs}}" wx:key="label">
          <text class="chip-label">{{item.label}}</text>
          <text class="chip-val">{{item.value}}</text>
        </view>
      </view>

      <view class="divider"/>

      <!-- Specs table -->
      <view class="spec-section" wx:if="{{product.spec_table && product.spec_table.length}}">
        <text class="sec-title">技术规格</text>
        <text class="sec-label">SPECIFICATIONS</text>
        <view class="spec-table">
          <view class="spec-row" wx:for="{{product.spec_table}}" wx:key="label">
            <text class="spec-label">{{item.label}}</text>
            <text class="spec-value">{{item.value}}</text>
          </view>
        </view>
      </view>

      <view class="divider"/>

      <!-- Features grid -->
      <view class="feat-section" wx:if="{{product.features && product.features.length}}">
        <text class="sec-title">核心优势</text>
        <text class="sec-label">FEATURES</text>
        <view class="feat-grid">
          <view class="feat-card" wx:for="{{product.features}}" wx:key="name">
            <text class="feat-icon">{{item.icon || '✦'}}</text>
            <text class="feat-name">{{item.name}}</text>
            <text class="feat-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="divider"/>

      <!-- Feature list -->
      <view class="feat-list-section" wx:if="{{product.highlights && product.highlights.length}}">
        <text class="sec-title">产品亮点</text>
        <text class="sec-label">HIGHLIGHTS</text>
        <view class="feat-list">
          <view class="feat-item" wx:for="{{product.highlights}}" wx:key="*this">
            <text class="feat-dot">·</text>
            <text class="feat-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="divider"/>

      <!-- Price -->
      <view class="price-section" wx:if="{{product.price}}">
        <view class="price-row">
          <text class="price-val">¥{{product.price}}</text>
          <text class="price-orig" wx:if="{{product.original_price}}">¥{{product.original_price}}</text>
        </view>
        <text class="price-note" wx:if="{{product.price_note}}">{{product.price_note}}</text>
      </view>
    </view>

    <!-- Bottom bar -->
    <view class="bottom-bar">
      <view class="bar-action">
        <text>💬</text>
        <text class="bar-action-label">客服</text>
      </view>
      <view class="bar-action">
        <text>🛒</text>
        <text class="bar-action-label">收藏</text>
      </view>
      <button class="consult-btn" bindtap="onConsult">咨询 · 购买</button>
    </view>
  </block>
</view>
