<view class="page">
  <!-- States -->
  <view class="state-box" wx:if="{{loading}}"><text class="state-text">加载中...</text></view>
  <view class="state-box" wx:elif="{{error && !product}}"><text class="state-text">加载失败，点击重试</text></view>
  <view class="state-box" wx:elif="{{!product}}"><text class="state-text">产品不存在</text></view>

  <block wx:if="{{product}}">
    <!-- Top nav (transparent over hero) -->
    <view class="top-nav" style="padding-top: {{statusBarHeight + 10}}px;">
      <view class="nav-back" bindtap="onBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <text class="nav-title">产品详情</text>
      <view class="nav-placeholder"/>
    </view>

    <!-- Product hero swiper -->
    <view class="product-hero">
      <swiper bindchange="onSwiperChange" indicator-dots="{{false}}" class="hero-swiper" circular="{{false}}" current="{{currentSlide}}">
        <swiper-item wx:for="{{product.images || []}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" class="hero-slide-img" bindtap="onPreviewImage"/>
        </swiper-item>
      </swiper>
      <view class="badge-row" wx:if="{{product.tags && product.tags.length}}">
        <text class="badge {{index === 0 ? 'hot' : ''}}" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="img-counter" wx:if="{{product.images && product.images.length}}">{{currentSlide + 1}} / {{product.images.length}}</text>
    </view>

    <!-- Detail panel (slides up over hero) -->
    <view class="detail-panel">
      <view class="panel-handle"/>

      <!-- Product header -->
      <view class="prod-header">
        <text class="brand">{{product.brand || 'ALI LAOXI'}}</text>
        <text class="pname">{{product.name || product.title}}</text>
        <text class="en-name" wx:if="{{product.en_name}}">{{product.en_name}}</text>
        <text class="pdesc">{{product.description || product.desc}}</text>
      </view>

      <!-- Spec chips -->
      <view class="spec-chips" wx:if="{{product.specs && product.specs.length}}">
        <view class="spec-chip" wx:for="{{product.specs}}" wx:key="label">
          <text class="chip-label">{{item.label}}</text>
          <text class="chip-val">{{item.value}}</text>
        </view>
      </view>

      <!-- Price section -->
      <view class="price-section">
        <view class="price-row">
          <text class="price">¥{{product.price || '6,999'}}</text>
          <text class="unit">{{product.price_unit || '包邮'}}</text>
        </view>
        <text class="price-note">{{product.price_note || '免费送货上门 · 1年质保 · 终身免费陪跑 · 一对一教学'}}</text>
      </view>

      <!-- Action bar -->
      <view class="action-bar">
        <button class="btn-primary" bindtap="onOpenQR">💬 联系客服</button>
      </view>

      <view class="divider"/>

      <!-- Specs table -->
      <view class="spec-section" wx:if="{{product.spec_table && product.spec_table.length}}">
        <text class="sec-title">参数规格</text>
        <text class="sec-label">SPECIFICATIONS</text>
        <view class="spec-table">
          <view class="spec-row" wx:for="{{product.spec_table}}" wx:key="label">
            <text class="spec-label-col">{{item.label}}</text>
            <text class="spec-value-col">{{item.value}}</text>
          </view>
        </view>
      </view>

      <view class="divider"/>

      <!-- Case gallery -->
      <view class="case-gallery" wx:if="{{product.cases && product.cases.length}}">
        <view class="case-gallery-header">
          <view>
            <text class="sec-title">真实案例</text>
            <text class="sec-label case-sec-label">CASES</text>
          </view>
          <text class="case-gallery-more" bindtap="onMoreCases">查看全部 ›</text>
        </view>
        <scroll-view scroll-x class="case-scroll">
          <view class="case-photo" wx:for="{{product.cases}}" wx:key="name" bindtap="onCaseTap" data-id="{{item.id}}">
            <view class="photo" style="background:{{item.bg || 'linear-gradient(135deg, #C8BFB4, #A89E93)'}};">
              <text class="case-label">{{item.tag || 'Before / After'}}</text>
            </view>
            <view class="case-meta">
              <text class="case-name">{{item.name}}</text>
              <text class="case-info">{{item.info}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="divider" wx:if="{{product.cases && product.cases.length}}"/>

      <!-- Features grid -->
      <view class="feat-grid-section" wx:if="{{product.features && product.features.length}}">
        <text class="sec-title">产品特色</text>
        <text class="sec-label">FEATURES</text>
        <view class="feat-grid">
          <view class="feat-card" wx:for="{{product.features}}" wx:key="name">
            <text class="feat-icon">{{item.icon || '✦'}}</text>
            <text class="feat-name">{{item.name}}</text>
            <text class="feat-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="divider" wx:if="{{product.features && product.features.length}}"/>

      <!-- Highlights list -->
      <view class="highlights-section" wx:if="{{product.highlights && product.highlights.length}}">
        <text class="sec-title">服务亮点</text>
        <text class="sec-label">HIGHLIGHTS</text>
        <view class="feat-list">
          <view class="feat-item" wx:for="{{product.highlights}}" wx:key="*this">
            <view class="feat-dot"/>
            <text class="feat-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="divider" wx:if="{{product.highlights && product.highlights.length}}"/>

      <!-- Related products -->
      <view class="related-section" wx:if="{{product.related && product.related.length}}">
        <text class="sec-title">相关产品</text>
        <text class="sec-label">RELATED</text>
        <scroll-view scroll-x class="related-scroll">
          <view class="related-card" wx:for="{{product.related}}" wx:key="id" bindtap="onRelatedTap" data-id="{{item.id}}">
            <image src="{{item.thumb || ''}}" mode="aspectFill" class="related-img" wx:if="{{item.thumb}}"/>
            <view class="related-placeholder" wx:else>
              <text class="related-placeholder-icon" wx:if="{{!item.id}}">+</text>
            </view>
            <view class="rinfo">
              <text class="rname">{{item.name}}</text>
              <text class="rsub">{{item.sub}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view style="height: 120rpx;"/>
    </view>

    <!-- Lightbox -->
    <view class="lightbox {{showLightbox ? 'show' : ''}}" wx:if="{{showLightbox}}">
      <view class="lightbox-close" bindtap="onCloseLightbox">
        <text class="lightbox-close-icon">✕</text>
      </view>
      <swiper bindchange="onLightboxChange" class="lightbox-swiper" current="{{lightboxIndex}}" indicator-dots="{{false}}">
        <swiper-item wx:for="{{product.images || []}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFit" class="lightbox-img"/>
        </swiper-item>
      </swiper>
      <text class="lightbox-counter">{{lightboxIndex + 1}} / {{product.images.length}}</text>
    </view>

    <!-- QR Modal overlay -->
    <view class="modal-overlay {{showQR ? 'show' : ''}}" catchtap="onCloseQR" wx:if="{{showQR}}">
      <view class="modal-box">
        <text class="modal-title">添加客服微信</text>
        <text class="modal-sub">扫码添加阿利老西进行下单咨询</text>
        <image src="{{product.qr_code || '/static/images/qr_placeholder.png'}}" mode="aspectFit" class="modal-qr"/>
        <button class="modal-close-btn" bindtap="onCloseQRBtn">关闭</button>
      </view>
    </view>
  </block>
</view>
