.product-detail-page { background: #F8F7F5; min-height: 100vh; padding-bottom: 140rpx; }

.product-hero { width: 100%; height: 500rpx; background: #1A1A1A; position: relative; }
.hero-swiper { width: 100%; height: 100%; }
.hero-slide-img { width: 100%; height: 100%; }
.hero-placeholder { width: 100%; height: 100%; background: #1A1A1A; }
.badge-row { position: absolute; top: 24rpx; left: 24rpx; display: flex; gap: 12rpx; }
.badge { background: rgba(255,255,255,0.12); color: #fff; font-size: 18rpx; padding: 8rpx 24rpx; border-radius: 28rpx; letter-spacing: 2rpx; border: 1px solid rgba(255,255,255,0.08); }
.badge.hot { background: rgba(200,90,58,0.8); }
.img-counter { position: absolute; bottom: 24rpx; right: 32rpx; font-size: 20rpx; color: rgba(255,255,255,0.5); }

.detail-panel { position: relative; background: #fff; border-radius: 32rpx 32rpx 0 0; margin-top: -58rpx; padding: 0 30rpx 40rpx; z-index: 10; box-shadow: 0 -4rpx 40rpx rgba(0,0,0,0.05); }
.panel-handle { width: 72rpx; height: 6rpx; border-radius: 3rpx; background: rgba(0,0,0,0.06); margin: 24rpx auto 32rpx; }

.prod-header { margin-bottom: 32rpx; }
.brand { font-size: 18rpx; letter-spacing: 8rpx; color: rgba(0,0,0,0.15); display: block; margin-bottom: 12rpx; }
.pname { font-size: 44rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 6rpx; display: block; margin-bottom: 6rpx; }
.en-name { font-size: 20rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.15); display: block; margin-bottom: 20rpx; }
.pdesc { font-size: 26rpx; color: rgba(0,0,0,0.4); line-height: 1.9; display: block; }

.spec-chips { display: flex; gap: 14rpx; flex-wrap: wrap; margin: 32rpx 0; }
.spec-chip { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; background: #F8F7F5; border-radius: 12rpx; border: 1px solid rgba(0,0,0,0.03); }
.chip-label { font-size: 18rpx; color: rgba(0,0,0,0.2); letter-spacing: 2rpx; }
.chip-val { font-size: 24rpx; color: #1A1A1A; font-weight: 500; }

.divider { height: 1px; background: rgba(0,0,0,0.06); margin: 32rpx 0; }

.sec-title { font-size: 30rpx; color: #1A1A1A; letter-spacing: 4rpx; display: block; margin-bottom: 4rpx; }
.sec-label { font-size: 18rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.15); display: block; margin-bottom: 24rpx; }

.spec-table { margin-bottom: 8rpx; }
.spec-row { display: flex; padding: 18rpx 0; border-bottom: 1px solid rgba(0,0,0,0.03); }
.spec-row:last-child { border-bottom: none; }
.spec-label { width: 140rpx; font-size: 24rpx; color: rgba(0,0,0,0.3); flex-shrink: 0; }
.spec-value { flex: 1; font-size: 24rpx; color: #1A1A1A; font-weight: 500; }

.feat-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }
.feat-card { width: calc(50% - 7rpx); background: #F8F7F5; border-radius: 16rpx; padding: 28rpx 20rpx; text-align: center; border: 1px solid rgba(0,0,0,0.02); }
.feat-icon { font-size: 40rpx; display: block; margin-bottom: 12rpx; }
.feat-name { font-size: 24rpx; color: #1A1A1A; font-weight: 500; display: block; margin-bottom: 6rpx; }
.feat-desc { font-size: 18rpx; color: rgba(0,0,0,0.25); display: block; line-height: 1.4; }

.feat-list { display: flex; flex-direction: column; gap: 16rpx; }
.feat-item { display: flex; align-items: flex-start; gap: 16rpx; }
.feat-dot { font-size: 24rpx; color: rgba(0,0,0,0.12); margin-top: 10rpx; }
.feat-text { font-size: 24rpx; color: rgba(0,0,0,0.4); line-height: 1.7; }

.price-section { margin: 24rpx 0; padding: 28rpx; background: #F8F7F5; border-radius: 16rpx; border: 1px solid rgba(0,0,0,0.02); }
.price-row { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 8rpx; }
.price-val { font-size: 48rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 2rpx; }
.price-orig { font-size: 24rpx; color: rgba(0,0,0,0.25); text-decoration: line-through; }
.price-note { font-size: 22rpx; color: rgba(0,0,0,0.35); }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 110rpx; padding: 0 30rpx; display: flex; align-items: center; gap: 20rpx; background: rgba(255,255,255,0.95); border-top: 1px solid rgba(0,0,0,0.04); z-index: 100; }
.bar-action { display: flex; flex-direction: column; align-items: center; gap: 2rpx; font-size: 32rpx; width: 80rpx; }
.bar-action-label { font-size: 20rpx; color: rgba(0,0,0,0.3); }
.consult-btn { flex: 1; padding: 28rpx; background: #1A1A1A; color: #fff; border: none; border-radius: 48rpx; font-size: 28rpx; letter-spacing: 4rpx; }
.error-box { text-align: center; padding: 200rpx 40rpx; color: #999; font-size: 28rpx; }
