<view class="page">
  <!-- Nav bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight + 10}}px;">
    <view class="nav-back" bindtap="onBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">动态详情</text>
    <view class="nav-more">
      <text class="nav-more-icon">⋯</text>
    </view>
  </view>

  <!-- States -->
  <view class="state-box" wx:if="{{loading}}"><text class="state-text">加载中...</text></view>
  <view class="state-box" wx:elif="{{error}}" bindtap="loadData"><text class="state-text">加载失败，点击重试</text></view>
  <view class="state-box" wx:elif="{{!moment}}"><text class="state-text">帖子不存在</text></view>

  <scroll-view scroll-y class="content-area" wx:if="{{moment}}">
    <!-- Post section -->
    <view class="post-section">
      <!-- Post header -->
      <view class="post-header">
        <image src="{{moment.user_avatar || '/static/images/def_avatar.png'}}" class="post-avatar" mode="aspectFill"/>
        <view class="post-user">
          <text class="post-name">{{moment.user_nickname || '用户'}}</text>
          <text class="post-time">{{moment.add_time || '刚刚'}} · 来自教学分享</text>
        </view>
      </view>

      <!-- Post content -->
      <text class="post-content">{{moment.content}}</text>

      <!-- Post images grid -->
      <view class="post-images" wx:if="{{moment.images && moment.images.length}}">
        <image src="{{item}}" mode="aspectFill" class="post-img" wx:for="{{moment.images}}" wx:key="*this" wx:if="{{index < 9}}" bindtap="onPreviewImage" data-urls="{{moment.images}}" data-current="{{item}}"/>
      </view>

      <!-- Post location -->
      <view class="post-location" wx:if="{{moment.location}}">
        <text class="location-icon">📍</text>
        <text>{{moment.location}}</text>
      </view>

      <!-- Post stats -->
      <view class="post-stats">
        <view class="stat-item" bindtap="onLike">
          <text class="stat-icon {{moment.is_liked ? 'liked' : ''}}">{{moment.is_liked ? '❤️' : '🤍'}}</text>
          <text class="stat-num">{{moment.like_count || 0}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">💬</text>
          <text class="stat-num">{{moment.comment_count || 0}}</text>
        </view>
      </view>
    </view>

    <!-- Comments section -->
    <view class="comments-section">
      <text class="comments-title">评论 · {{moment.comment_count || 0}}</text>

      <view class="comment-item" wx:for="{{moment.comments || []}}" wx:key="id">
        <image src="{{item.avatar || '/static/images/def_avatar.png'}}" class="comment-avatar" mode="aspectFill"/>
        <view class="comment-body">
          <text class="comment-name">{{item.nickname || '用户'}}</text>
          <text class="comment-text">{{item.content}}</text>
          <view class="comment-meta">
            <text>{{item.add_time || '刚刚'}}</text>
            <text catchtap="onReply" data-parent-id="{{item.id}}" data-nickname="{{item.nickname}}">回复</text>
            <text>♡ {{item.like_count || 0}}</text>
          </view>
        </view>
      </view>

      <view class="comment-more" wx:if="{{showMoreComments}}">
        <text>查看更多评论 ›</text>
      </view>

      <view class="comment-empty" wx:if="{{showEmptyComments}}">
        <text>暂无评论，来说点什么吧</text>
      </view>
    </view>

    <view style="height: 140rpx;"/>
  </scroll-view>

  <!-- Input bar -->
  <view class="input-bar" wx:if="{{moment}}">
    <block wx:if="{{isLogin && isMember}}">
      <input class="input-field" placeholder="写评论..." value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="onSendComment"/>
    </block>
    <text wx:elif="{{!isLogin}}" class="login-tip" bindtap="onGoLogin">登录后评论</text>
    <text wx:else class="login-tip" bindtap="onGoTeaching">开通会员后可评论</text>
    <view class="input-actions">
      <view class="input-action" bindtap="onToggleLike">
        <text>{{moment.is_liked ? '❤️' : '🤍'}}</text>
      </view>
    </view>
  </view>
</view>
