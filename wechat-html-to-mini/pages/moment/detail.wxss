/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; position: relative; }

/* ===== Nav bar ===== */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-back, .nav-more { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(0,0,0,0.04); display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 40rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }
.nav-more-icon { font-size: 32rpx; color: #1A1A1A; }

/* ===== States ===== */
.state-box { display: flex; align-items: center; justify-content: center; padding: 200rpx 40rpx; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }

/* ===== Post section ===== */
.content-area { padding-bottom: 140rpx; }
.post-section { padding: 0 40rpx; }
.post-header { display: flex; align-items: center; gap: 24rpx; margin-bottom: 32rpx; }
.post-avatar { width: 84rpx; height: 84rpx; border-radius: 50%; background: #F0EFED; flex-shrink: 0; }
.post-user { flex: 1; }
.post-name { font-size: 28rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 1rpx; display: block; }
.post-time { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; margin-top: 4rpx; display: block; }

.post-content { font-size: 28rpx; color: #1A1A1A; line-height: 1.8; font-weight: 300; margin-bottom: 32rpx; display: block; }

/* Post images grid */
.post-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 32rpx; border-radius: 16rpx; overflow: hidden; }
.post-img { width: calc((100% - 16rpx) / 3); height: 220rpx; background: #F0EFED; }
.post-img:nth-child(2) { background: #EBE9E6; }
.post-img:nth-child(3) { background: #E8E6E3; }
.post-img:nth-child(4) { background: #F2F0ED; }
.post-img:nth-child(5) { background: #EDEBE8; }
.post-img:nth-child(6) { background: #EBE9E6; }

/* Post location */
.post-location { display: flex; align-items: center; gap: 12rpx; margin-bottom: 40rpx; font-size: 24rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.location-icon { font-size: 24rpx; }

/* Post stats */
.post-stats { display: flex; gap: 48rpx; padding: 32rpx 0; border-top: 2rpx solid rgba(0,0,0,0.04); border-bottom: 2rpx solid rgba(0,0,0,0.04); margin-bottom: 40rpx; }
.stat-item { display: flex; align-items: center; gap: 12rpx; }
.stat-icon { font-size: 32rpx; }
.stat-icon.liked { color: #e93323; }
.stat-num { font-size: 24rpx; color: rgba(0,0,0,0.35); font-weight: 300; }

/* ===== Comments section ===== */
.comments-section { padding: 0 40rpx 40rpx; }
.comments-title { font-size: 22rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.3); text-transform: uppercase; margin-bottom: 32rpx; font-weight: 400; display: block; }
.comment-item { display: flex; gap: 24rpx; margin-bottom: 36rpx; }
.comment-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #F0EFED; flex-shrink: 0; }
.comment-body { flex: 1; }
.comment-name { font-size: 24rpx; font-weight: 400; color: #1A1A1A; margin-bottom: 6rpx; display: block; }
.comment-text { font-size: 26rpx; color: rgba(0,0,0,0.5); line-height: 1.6; font-weight: 300; display: block; }
.comment-meta { display: flex; gap: 32rpx; margin-top: 12rpx; }
.comment-meta text { font-size: 22rpx; color: rgba(0,0,0,0.25); font-weight: 300; }
.comment-more { text-align: center; padding: 24rpx 0; font-size: 24rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.comment-empty { text-align: center; padding: 40rpx 0; font-size: 24rpx; color: rgba(0,0,0,0.2); font-weight: 300; }

/* ===== Input bar ===== */
.input-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 40rpx 40rpx; display: flex; align-items: center; gap: 24rpx; background: rgba(255,255,255,0.95); border-top: 2rpx solid rgba(0,0,0,0.04); z-index: 100; }
.input-field { flex: 1; padding: 20rpx 32rpx; border: 2rpx solid rgba(0,0,0,0.08); border-radius: 40rpx; font-size: 26rpx; color: rgba(0,0,0,0.3); background: #FAFAF8; }
.input-actions { display: flex; gap: 16rpx; }
.input-action { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; }
.login-tip { flex: 1; text-align: center; font-size: 26rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
