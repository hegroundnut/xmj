/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; position: relative; padding-bottom: 120rpx; }

/* ===== Page header ===== */
.page-header { padding: 16rpx 48rpx 32rpx; background: linear-gradient(180deg, #E8DDD3 0%, #EDE4DA 40%, #F3ECE5 70%, #fff 100%); }
.page-title { font-size: 52rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 6rpx; animation: titleFadeIn 0.8s ease-out 0.6s both; }

.wm-wrap { position: relative; height: 100rpx; overflow: hidden; margin-bottom: 8rpx; }
.wm { position: absolute; opacity: 0; }
.wm-class { font-size: 56rpx; font-weight: 700; color: rgba(255,255,255,0.35); letter-spacing: 6rpx; top: 4rpx; left: -12rpx; text-shadow: 0 0 20rpx rgba(255,255,255,0.08); transform: rotate(-5deg); animation: wmFadeIn 0.7s ease-out 0.1s forwards; }
.wm-ali { font-size: 40rpx; font-weight: 300; color: rgba(255,255,255,0.3); letter-spacing: 4rpx; top: 28rpx; left: 160rpx; text-shadow: 0 0 16rpx rgba(255,255,255,0.06); transform: rotate(6deg); animation: wmFadeIn 0.7s ease-out 0.3s forwards; }
.wm-study { font-size: 48rpx; font-weight: 700; color: rgba(255,255,255,0.25); letter-spacing: 4rpx; top: 12rpx; left: 360rpx; text-shadow: 0 0 20rpx rgba(255,255,255,0.08); transform: rotate(-3deg); animation: wmFadeIn 0.7s ease-out 0.5s forwards; }

@keyframes wmFadeIn {
  from { opacity: 0; transform: translateY(24rpx) rotate(0deg); }
  to { opacity: 1; transform: translateY(0) rotate(-5deg); }
}
@keyframes titleFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Member card ===== */
.member-card { margin: 0 40rpx 40rpx; padding: 0; border-radius: 24rpx; background: #F0EBE0; border: 2rpx solid rgba(107,118,79,0.12); position: relative; overflow: hidden; min-height: 330rpx; }
.member-watermark { position: absolute; top: 45%; left: 50%; transform: translate(-50%,-50%); font-size: 84rpx; font-weight: 900; color: rgba(107,118,79,0.1); letter-spacing: 12rpx; white-space: nowrap; pointer-events: none; z-index: 1; }
.member-deco { position: absolute; font-size: 16rpx; color: rgba(107,118,79,0.2); letter-spacing: 4rpx; font-weight: 400; z-index: 1; pointer-events: none; }
.member-content { position: relative; z-index: 2; padding: 28rpx 40rpx; }
.member-label { font-size: 16rpx; letter-spacing: 6rpx; color: #6B764F; text-transform: uppercase; margin-bottom: 10rpx; opacity: 0.5; font-weight: 400; display: block; }
.member-title { font-size: 30rpx; font-weight: 800; color: #6B764F; letter-spacing: 4rpx; margin-bottom: 6rpx; display: block; }
.member-desc { font-size: 20rpx; color: #6B764F; font-weight: 300; margin-bottom: 20rpx; letter-spacing: 2rpx; opacity: 0.55; display: block; }
.member-btn { display: inline-block; padding: 12rpx 40rpx; background: #6B764F; color: #F0EBE0; font-size: 20rpx; border-radius: 40rpx; letter-spacing: 4rpx; font-weight: 500; }

/* ===== Tabs ===== */
.tabs { display: flex; padding: 0 40rpx; border-bottom: 2rpx solid rgba(0,0,0,0.06); }
.tab { flex: 1; text-align: center; padding: 20rpx 0; position: relative; display: flex; flex-direction: column; align-items: center; gap: 2rpx; }
.tab .en { font-size: 20rpx; font-weight: 600; letter-spacing: 3rpx; color: rgba(0,0,0,0.22); }
.tab .cn { font-size: 26rpx; font-weight: 400; color: rgba(0,0,0,0.35); letter-spacing: 1rpx; }
.tab.active .en { color: #1A1A1A; }
.tab.active .cn { color: #1A1A1A; font-weight: 500; }
.tab.active::after { content: ''; position: absolute; bottom: -2rpx; left: 50%; transform: translateX(-50%); width: 40rpx; height: 3rpx; background: #1A1A1A; border-radius: 2rpx; }

/* ===== Category bar ===== */
.cat-bar { padding: 24rpx 40rpx; white-space: nowrap; }
.cat-inner { display: inline-flex; gap: 16rpx; }
.cat-tag { display: inline-block; padding: 10rpx 28rpx; border-radius: 28rpx; font-size: 22rpx; color: rgba(0,0,0,0.35); background: rgba(0,0,0,0.03); font-weight: 400; letter-spacing: 1rpx; flex-shrink: 0; }
.cat-tag.active { color: #fff; background: #1A1A1A; font-weight: 500; }

/* ===== Course list ===== */
.course-list { padding: 0 40rpx; }
.course-card { display: flex; gap: 28rpx; padding: 32rpx 0; border-bottom: 2rpx solid rgba(0,0,0,0.04); }
.course-card:last-child { border-bottom: none; }
.course-thumb { width: 260rpx; height: 164rpx; border-radius: 16rpx; flex-shrink: 0; overflow: hidden; position: relative; background: #F0EFED; }
.course-thumb-img { width: 100%; height: 100%; }
.course-tag { position: absolute; top: 12rpx; left: 12rpx; background: #1A1A1A; color: #fff; font-size: 18rpx; padding: 4rpx 16rpx; border-radius: 20rpx; letter-spacing: 1rpx; }
.course-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; padding: 4rpx 0; }
.course-name { font-size: 26rpx; font-weight: 400; color: #1A1A1A; line-height: 1.5; letter-spacing: 1rpx; display: block; }
.course-desc { font-size: 22rpx; color: rgba(0,0,0,0.3); line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; font-weight: 300; }
.course-bottom { display: flex; align-items: center; justify-content: space-between; }
.course-price { font-size: 26rpx; font-weight: 500; color: #1A1A1A; }
.course-price .orig { font-size: 22rpx; color: rgba(0,0,0,0.2); font-weight: 300; text-decoration: line-through; margin-left: 8rpx; }
.course-meta { font-size: 20rpx; color: rgba(0,0,0,0.25); font-weight: 300; }
.course-bottom-right { display: flex; align-items: center; gap: 16rpx; }
.course-buy { padding: 10rpx 28rpx; border-radius: 32rpx; background: #1A1A1A; color: #fff; font-size: 20rpx; font-weight: 400; letter-spacing: 2rpx; flex-shrink: 0; }

.empty-courses { text-align: center; padding: 80rpx 0; color: rgba(0,0,0,0.2); font-size: 26rpx; }

/* ===== QR Modal ===== */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 200; display: none; align-items: center; justify-content: center; }
.modal-overlay.show { display: flex; animation: modalFadeIn 0.3s ease; }
@keyframes modalFadeIn { from { opacity: 0; } to { opacity: 1; } }
.modal-card { background: #fff; border-radius: 32rpx; padding: 56rpx 48rpx 48rpx; width: 560rpx; text-align: center; position: relative; animation: modalSlideUp 0.35s ease; }
@keyframes modalSlideUp { from { opacity: 0; transform: translateY(40rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-close { position: absolute; top: 24rpx; right: 28rpx; width: 48rpx; height: 48rpx; border-radius: 50%; background: rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: rgba(0,0,0,0.3); line-height: 1; }
.modal-label { font-size: 18rpx; letter-spacing: 6rpx; color: #6B764F; text-transform: uppercase; opacity: 0.5; margin-bottom: 12rpx; display: block; }
.modal-title { font-size: 30rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 28rpx; letter-spacing: 2rpx; display: block; }
.modal-qr { width: 320rpx; height: 320rpx; margin: 0 auto 28rpx; border-radius: 20rpx; border: 2rpx solid rgba(0,0,0,0.06); overflow: hidden; background: #FAFAF8; }
.modal-qr-img { width: 100%; height: 100%; }
.modal-desc { font-size: 22rpx; color: rgba(0,0,0,0.4); line-height: 1.6; letter-spacing: 0.6rpx; font-weight: 300; white-space: pre-line; display: block; }
.modal-strong { color: #6B764F; font-weight: 500; }
.modal-hint { margin-top: 20rpx; font-size: 20rpx; color: rgba(0,0,0,0.25); letter-spacing: 1rpx; display: block; }

/* ===== State ===== */
.state-box { display: flex; align-items: center; justify-content: center; height: 100vh; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
