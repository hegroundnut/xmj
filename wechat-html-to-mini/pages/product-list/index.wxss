.product-list-page { background: #F8F7F5; min-height: 100vh; padding-bottom: 40rpx; }

.filter-bar { display: flex; gap: 14rpx; padding: 20rpx 30rpx; white-space: nowrap; background: #F8F7F5; }
.filter-tag { flex-shrink: 0; padding: 14rpx 32rpx; border-radius: 40rpx; border: 1px solid rgba(0,0,0,0.06); font-size: 22rpx; color: rgba(0,0,0,0.35); display: inline-block; }
.filter-tag.active { background: #1A1A1A; color: #fff; border-color: #1A1A1A; }

.product-grid { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 30rpx 40rpx; }
.prod-card { width: calc(50% - 8rpx); background: #fff; border-radius: 16rpx; overflow: hidden; border: 1px solid rgba(0,0,0,0.03); }
.prod-card.featured { width: 100%; display: flex; }
.prod-card.featured .card-thumb { width: 240rpx; height: 220rpx; flex-shrink: 0; }
.prod-card.featured .card-info { flex: 1; padding: 28rpx; justify-content: center; }

.card-thumb { width: 100%; height: 280rpx; background: #EDEBE8; position: relative; overflow: hidden; }
.thumb-img { width: 100%; height: 100%; }
.thumb-tag { position: absolute; top: 14rpx; left: 14rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 16rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.thumb-tag.hot { background: rgba(200,90,58,0.8); }

.card-info { padding: 20rpx; }
.card-name { font-size: 26rpx; color: #1A1A1A; font-weight: 500; display: block; margin-bottom: 6rpx; }
.card-sub { font-size: 20rpx; color: rgba(0,0,0,0.25); display: block; margin-bottom: 10rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-price { font-size: 30rpx; color: #1A1A1A; font-weight: 600; display: block; }
.error-box { text-align: center; padding: 200rpx 40rpx; color: #999; font-size: 28rpx; }
