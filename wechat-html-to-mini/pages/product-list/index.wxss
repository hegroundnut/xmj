/* ===== Page ===== */
.page { background: #F8F7F5; min-height: 100vh; position: relative; }

/* ===== Top nav ===== */
.top-nav { display: flex; align-items: center; padding: 0 40rpx 24rpx; position: sticky; top: 0; z-index: 10; background: rgba(248,247,245,0.95); }
/* WeChat mini program doesn't support backdrop-filter, so we omit it */
.nav-back { width: 68rpx; height: 68rpx; border-radius: 50%; background: rgba(0,0,0,0.04); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.nav-back-icon { font-size: 36rpx; color: rgba(0,0,0,0.5); font-weight: 300; line-height: 1; }
.nav-title { flex: 1; text-align: center; font-size: 28rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 4rpx; margin-right: 68rpx; }
.nav-placeholder { width: 68rpx; }

/* ===== Page header ===== */
.page-header { padding: 16rpx 48rpx 32rpx; background: linear-gradient(180deg, #E8DDD3 0%, #EDE4DA 40%, #F3ECE5 70%, #F8F7F5 100%); }
.page-title { font-size: 52rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 6rpx; animation: titleFadeIn 0.8s ease-out 0.6s both; }

/* Watermark animated text */
.wm-wrap { position: relative; height: 100rpx; overflow: hidden; margin-bottom: 8rpx; }
.wm { position: absolute; opacity: 0; }
.wm-ali { font-size: 56rpx; font-weight: 700; color: rgba(255,255,255,0.35); letter-spacing: 6rpx; top: 4rpx; left: -10rpx; text-shadow: 0 0 20rpx rgba(255,255,255,0.08); transform: rotate(-8deg); animation: wmFadeIn 0.7s ease-out 0.1s forwards; }
.wm-studio { font-size: 40rpx; font-weight: 700; color: rgba(255,255,255,0.25); letter-spacing: 4rpx; top: 36rpx; left: 180rpx; text-shadow: 0 0 16rpx rgba(255,255,255,0.06); transform: rotate(5deg); animation: wmFadeIn 0.7s ease-out 0.3s forwards; }
.wm-brow { font-size: 64rpx; font-weight: 300; color: rgba(255,255,255,0.3); letter-spacing: 8rpx; top: 16rpx; left: 360rpx; text-shadow: 0 0 20rpx rgba(255,255,255,0.08); transform: rotate(-3deg); animation: wmFadeIn 0.7s ease-out 0.5s forwards; }

@keyframes wmFadeIn {
  from { opacity: 0; transform: translateY(24rpx) rotate(0deg); }
  to { opacity: 1; transform: translateY(0) rotate(-8deg); }
}
@keyframes titleFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Filter bar ===== */
.filter-bar { display: flex; gap: 16rpx; padding: 0 40rpx 32rpx; white-space: nowrap; }
.filter-tag { flex-shrink: 0; padding: 14rpx 32rpx; border-radius: 40rpx; border: 2rpx solid rgba(0,0,0,0.06); background: transparent; font-size: 22rpx; color: rgba(0,0,0,0.35); letter-spacing: 1rpx; font-weight: 300; }
.filter-tag.active { background: #1A1A1A; color: #fff; border-color: #1A1A1A; font-weight: 400; }

/* ===== Product grid ===== */
.product-grid { display: flex; flex-wrap: wrap; gap: 20rpx; padding: 0 40rpx 220rpx; }
.prod-card { width: calc(50% - 10rpx); border-radius: 24rpx; overflow: hidden; background: #fff; border: 2rpx solid rgba(0,0,0,0.03); }

/* Featured card */
.featured { width: 100%; border-radius: 24rpx; overflow: hidden; background: #fff; display: flex; border: 2rpx solid rgba(0,0,0,0.03); }
.featured:active { transform: scale(0.98); }
.feat-thumb { width: 300rpx; height: 260rpx; overflow: hidden; background: #1A1A1A; flex-shrink: 0; }
.feat-img { width: 100%; height: 100%; opacity: 0.92; }
.feat-info { flex: 1; padding: 32rpx; display: flex; flex-direction: column; justify-content: center; }
.feat-badge { display: inline-flex; padding: 6rpx 20rpx; background: #F0EFED; border-radius: 20rpx; font-size: 16rpx; color: rgba(0,0,0,0.4); letter-spacing: 2rpx; margin-bottom: 16rpx; font-weight: 400; align-self: flex-start; }
.feat-name { font-size: 28rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 4rpx; margin-bottom: 8rpx; display: block; }
.feat-sub { font-size: 20rpx; color: rgba(0,0,0,0.3); font-weight: 300; margin-bottom: 16rpx; line-height: 1.5; display: block; }
.feat-arrow { font-size: 22rpx; color: rgba(0,0,0,0.25); letter-spacing: 2rpx; }

/* Regular card */
.prod-card:active { transform: scale(0.97); }
.card-thumb { width: 100%; height: 300rpx; overflow: hidden; background: #EDEBE8; position: relative; }
.thumb-img { width: 100%; height: 100%; }
.thumb-tag { position: absolute; top: 16rpx; left: 16rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 16rpx; font-weight: 500; padding: 6rpx 16rpx; border-radius: 20rpx; letter-spacing: 1rpx; }
.thumb-tag.hot { background: rgba(200,90,58,0.8); }
.card-info { padding: 24rpx; }
.card-name { font-size: 24rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 1rpx; margin-bottom: 6rpx; display: block; }
.card-sub { font-size: 20rpx; color: rgba(0,0,0,0.25); font-weight: 300; margin-bottom: 12rpx; display: block; }
.card-price { font-size: 30rpx; color: #1A1A1A; font-weight: 600; letter-spacing: 0.6rpx; display: block; margin-top: 8rpx; }

/* ===== Empty state ===== */
.empty-state { width: 100%; text-align: center; padding: 120rpx 40rpx; }
.empty-title { font-size: 28rpx; color: rgba(0,0,0,0.25); font-weight: 300; letter-spacing: 2rpx; margin-bottom: 12rpx; display: block; }
.empty-sub { font-size: 22rpx; color: rgba(0,0,0,0.15); font-weight: 300; display: block; }

/* ===== State ===== */
.state-box { display: flex; align-items: center; justify-content: center; height: 100vh; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
