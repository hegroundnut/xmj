/* ===== Splash page ===== */
.splash-page { position: relative; width: 100vw; height: 100vh; overflow: hidden; background: #E8E4DF; }

/* Background blurred image */
.bg-img { position: absolute; inset: -40rpx; width: calc(100vw + 80rpx); height: calc(100vh + 80rpx); filter: blur(50rpx); z-index: 1; }

/* Dark overlay */
.overlay { position: absolute; inset: 0; z-index: 2; background: rgba(0,0,0,0.08); }

/* Status bar */
.status-bar { position: absolute; top: 0; left: 0; right: 0; z-index: 10; display: flex; justify-content: space-between; align-items: center; padding-left: 56rpx; padding-right: 56rpx; height: 88rpx; }
.status-time { font-size: 30rpx; font-weight: 400; color: rgba(255,255,255,0.5); }
.status-icons { display: flex; gap: 10rpx; align-items: center; }
.status-icon { font-size: 24rpx; color: rgba(255,255,255,0.4); }

/* Brand center */
.brand { position: absolute; inset: 0; z-index: 5; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 64rpx; }
.brand-en { font-size: 20rpx; letter-spacing: 16rpx; color: rgba(255,255,255,0.55); text-transform: uppercase; font-weight: 300; margin-bottom: 36rpx; }
.brand-cn { font-size: 64rpx; font-weight: 200; color: #fff; letter-spacing: 28rpx; line-height: 1.3; margin-bottom: 24rpx; text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.08); }
.divider { width: 56rpx; height: 2rpx; background: rgba(255,255,255,0.35); margin-bottom: 32rpx; }
.tagline { font-size: 22rpx; color: rgba(255,255,255,0.5); letter-spacing: 8rpx; font-weight: 300; line-height: 2; }

/* Bottom line */
.bottom-line { position: absolute; bottom: 200rpx; left: 50%; transform: translateX(-50%); z-index: 5; }
.bottom-line text { font-size: 16rpx; letter-spacing: 10rpx; color: rgba(255,255,255,0.22); text-transform: uppercase; font-weight: 300; }

/* Enter button */
.enter-btn { position: absolute; bottom: 88rpx; left: 50%; transform: translateX(-50%); z-index: 10; padding: 18rpx 64rpx; border: 2rpx solid rgba(255,255,255,0.3); border-radius: 48rpx; }
.enter-btn text { font-size: 26rpx; color: rgba(255,255,255,0.6); letter-spacing: 8rpx; font-weight: 300; }

/* Animations */
.fade-up { animation: fadeUp 1.4s cubic-bezier(0.16,1,0.3,1) both; }
.fade-up-d1 { animation: fadeUp 1.4s cubic-bezier(0.16,1,0.3,1) 0.2s both; }
.fade-up-d2 { animation: fadeUp 1.4s cubic-bezier(0.16,1,0.3,1) 0.4s both; }
.fade-up-d3 { animation: fadeUp 1.4s cubic-bezier(0.16,1,0.3,1) 0.6s both; }
.fade-in { animation: fadeIn 1.8s ease-out 0.1s both; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(36rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
