/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; }

/* ===== Nav bar ===== */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-back { width: 64rpx; height: 64rpx; border-radius: 50%; background: #FAFAF8; display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 36rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }
.nav-right { width: 64rpx; }

/* ===== Filter tabs ===== */
.filter-scroll { white-space: nowrap; }
.filter-tabs { display: flex; gap: 16rpx; padding: 24rpx 40rpx 32rpx; }
.filter-tab { display: inline-block; padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 24rpx; color: rgba(0,0,0,0.35); font-weight: 300; border: 2rpx solid rgba(0,0,0,0.06); background: transparent; letter-spacing: 1rpx; }
.filter-tab.active { background: #1A1A1A; color: #fff; border-color: #1A1A1A; font-weight: 400; }

/* ===== Content ===== */
.content-area { padding: 0 40rpx 80rpx; }
.state-box { display: flex; align-items: center; justify-content: center; padding: 120rpx 0; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.empty-hint { text-align: center; padding: 120rpx 40rpx; color: rgba(0,0,0,0.2); font-size: 26rpx; font-weight: 300; }
.section-count { font-size: 22rpx; color: rgba(0,0,0,0.25); font-weight: 300; letter-spacing: 1rpx; margin-bottom: 24rpx; display: block; }

/* ===== Fav card ===== */
.fav-card { display: flex; gap: 24rpx; padding: 28rpx; background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; margin-bottom: 20rpx; }
.fav-thumb { width: 160rpx; height: 120rpx; border-radius: 12rpx; background: #F0EFED; flex-shrink: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.thumb-icon { font-size: 48rpx; color: rgba(0,0,0,0.1); }
.thumb-img { width: 100%; height: 100%; }
.fav-body { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.fav-title { font-size: 26rpx; color: #1A1A1A; font-weight: 400; letter-spacing: 0.6rpx; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.fav-meta { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.fav-tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 24rpx; font-size: 20rpx; font-weight: 400; letter-spacing: 1rpx; border: 2rpx solid rgba(0,0,0,0.08); color: rgba(0,0,0,0.4); background: #fff; line-height: 1.5; }
.fav-date { font-size: 20rpx; color: rgba(0,0,0,0.2); font-weight: 300; letter-spacing: 0.6rpx; }
.fav-actions { display: flex; align-items: center; margin-left: auto; flex-shrink: 0; }
.fav-unsave { font-size: 22rpx; color: rgba(0,0,0,0.25); font-weight: 300; }
