/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; }

/* ===== Nav bar ===== */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-back { width: 64rpx; height: 64rpx; border-radius: 50%; background: #FAFAF8; display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 36rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }
.nav-right { width: 64rpx; }

/* ===== States ===== */
.state-box { display: flex; align-items: center; justify-content: center; padding: 200rpx 40rpx; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.empty-hint { text-align: center; padding: 200rpx 40rpx; color: rgba(0,0,0,0.2); font-size: 26rpx; font-weight: 300; }

/* ===== Course list ===== */
.course-list { padding: 0 40rpx 80rpx; }
.course-item { display: flex; align-items: center; gap: 24rpx; padding: 28rpx 0; border-bottom: 2rpx solid rgba(0,0,0,0.04); }
.course-item:last-child { border-bottom: none; }
.course-thumb { width: 220rpx; height: 144rpx; border-radius: 12rpx; background: #F0EFED; flex-shrink: 0; }
.course-thumb-placeholder { display: flex; align-items: center; justify-content: center; font-size: 56rpx; }
.course-info { flex: 1; min-width: 0; }
.course-name { font-size: 28rpx; color: #1A1A1A; font-weight: 400; letter-spacing: 1rpx; display: block; margin-bottom: 6rpx; }
.course-desc { font-size: 24rpx; color: rgba(0,0,0,0.35); font-weight: 300; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 12rpx; }
.course-meta { display: flex; gap: 24rpx; }
.meta-item { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.course-arrow { font-size: 28rpx; color: rgba(0,0,0,0.15); flex-shrink: 0; }
