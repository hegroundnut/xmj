<view class="page">
  <!-- Nav bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight + 10}}px;">
    <view class="nav-btn">
      <text class="nav-btn-icon">‹</text>
    </view>
    <text class="nav-title">我的</text>
    <view class="nav-btn">
      <text class="nav-btn-icon">◎</text>
    </view>
  </view>

  <!-- Watermark deco -->
  <view class="deco-text">
    <text class="wm wm-profile">PROFILE</text>
    <text class="wm wm-ali">ALI LAOXI</text>
  </view>

  <!-- Profile header -->
  <view class="profile-header">
    <view class="avatar">
      <image src="{{userInfo.avatar || ''}}" mode="aspectFill" class="avatar-img" wx:if="{{userInfo.avatar}}"/>
      <text class="avatar-placeholder" wx:else>👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '阿利老西用户'}}</text>
      <text class="user-id">ID: {{userInfo.id || 'ALX20260001'}}</text>
    </view>
    <view class="edit-btn" bindtap="onEditProfile">编辑资料</view>
  </view>

  <!-- Member card -->
  <view class="member-card">
    <text class="member-watermark">ALI LAOXI</text>
    <text class="member-deco" style="top:16px;right:20px;">BROW STUDIO</text>
    <text class="member-deco" style="bottom:16px;left:24px;">EST. 2020</text>
    <text class="member-deco" style="bottom:16px;right:20px;">HEFEI</text>
    <view class="member-content">
      <text class="member-label">ALI LAOXI MEMBER</text>
      <text class="member-title">开通会员 · 畅享全部课程</text>
      <text class="member-desc">128+精品课程 · 持续更新 · 专属社群</text>
      <view class="member-btn" bindtap="onOpenMember">立即开通</view>
    </view>
  </view>

  <!-- Menu: Orders & Service -->
  <view class="menu-section">
    <text class="menu-title">订单与服务</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="onNav" data-url="/pages/my/bookings">
        <text class="menu-icon">📦</text>
        <text class="menu-text">我的订单</text>
        <text class="menu-badge">2</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onOpenQR">
        <text class="menu-icon">💬</text>
        <text class="menu-text">在线客服</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Menu: Learning -->
  <view class="menu-section">
    <text class="menu-title">学习中心</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="onNav" data-url="/pages/my/courses">
        <text class="menu-icon">🎬</text>
        <text class="menu-text">我的课程</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onNav" data-url="/pages/my/favorites">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Menu: Account -->
  <view class="menu-section">
    <text class="menu-title">账号</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="onNav" data-url="/subpackages/users/privacy/index?type=privacy">
        <text class="menu-icon">🛡</text>
        <text class="menu-text">隐私政策</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <text class="menu-icon">ℹ</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Login / Logout -->
  <view class="account-footer">
    <view class="login-btn" bindtap="onGoLogin" wx:if="{{!isLogin}}">登录 / 注册</view>
    <view class="logout-btn" bindtap="onLogout" wx:if="{{isLogin}}">退出登录</view>
  </view>

  <view class="bottom-spacer"/>

  <!-- QR Modal -->
  <view class="modal-overlay {{showQR ? 'show' : ''}}" catchtap="onCloseQR" wx:if="{{showQR}}">
    <view class="modal-card">
      <view class="modal-close" bindtap="onCloseQR">✕</view>
      <text class="modal-label">ALI LAOXI MEMBER</text>
      <text class="modal-title">扫码添加阿利老西</text>
      <view class="modal-qr">
        <image src="/static/images/qr_placeholder.png" mode="aspectFit" class="modal-qr-img"/>
      </view>
      <text class="modal-desc">打开微信扫描二维码，添加<text class="modal-strong">阿利老西</text>\n即可咨询会员详情并下单</text>
      <text class="modal-hint">长按识别二维码 · 添加微信好友</text>
    </view>
  </view>
</view>
