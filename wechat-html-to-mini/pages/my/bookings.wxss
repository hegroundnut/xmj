/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; }

/* ===== Nav bar ===== */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-back { width: 64rpx; height: 64rpx; border-radius: 50%; background: #FAFAF8; display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 36rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }
.nav-right { width: 64rpx; }

/* ===== States ===== */
.state-box { display: flex; align-items: center; justify-content: center; padding: 200rpx 40rpx; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.empty-hint { text-align: center; padding: 200rpx 40rpx; color: rgba(0,0,0,0.2); font-size: 26rpx; font-weight: 300; }

/* ===== Booking list ===== */
.booking-list { padding: 0 40rpx 80rpx; }
.booking-item { padding: 32rpx; background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; margin-bottom: 20rpx; }
.booking-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.booking-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; }
.booking-status { font-size: 22rpx; color: #07C160; font-weight: 400; padding: 4rpx 16rpx; background: rgba(7,193,96,0.08); border-radius: 20rpx; }
.booking-status.cancelled { color: rgba(0,0,0,0.3); background: rgba(0,0,0,0.04); }
.booking-meta { display: flex; flex-direction: column; gap: 10rpx; }
.meta-row { display: flex; align-items: center; gap: 12rpx; font-size: 26rpx; color: rgba(0,0,0,0.45); font-weight: 300; }
.meta-icon { font-size: 28rpx; width: 36rpx; text-align: center; flex-shrink: 0; }
