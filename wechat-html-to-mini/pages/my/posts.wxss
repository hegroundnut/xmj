/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; }

/* ===== Nav bar ===== */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-back { width: 64rpx; height: 64rpx; border-radius: 50%; background: #FAFAF8; display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 36rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }
.nav-right { width: 64rpx; }

/* ===== States ===== */
.state-box { display: flex; align-items: center; justify-content: center; padding: 200rpx 40rpx; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.empty-hint { text-align: center; padding: 200rpx 40rpx; color: rgba(0,0,0,0.2); font-size: 26rpx; font-weight: 300; }

/* ===== Post list ===== */
.post-list { padding: 0 40rpx 80rpx; }
.post-item { padding: 32rpx; background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; margin-bottom: 20rpx; }
.post-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.post-content { flex: 1; font-size: 28rpx; color: #1A1A1A; line-height: 1.6; font-weight: 300; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
.post-delete { font-size: 24rpx; color: rgba(0,0,0,0.3); flex-shrink: 0; margin-left: 24rpx; font-weight: 300; }

/* Post images */
.post-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 20rpx; }
.post-img { width: calc((100% - 16rpx) / 3); height: 160rpx; border-radius: 8rpx; background: #F0EFED; }
.post-img:nth-child(2) { background: #EBE9E6; }
.post-img:nth-child(3) { background: #E8E6E3; }

.post-footer { display: flex; justify-content: space-between; align-items: center; }
.post-stats { display: flex; gap: 32rpx; font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.post-time { font-size: 22rpx; color: rgba(0,0,0,0.2); font-weight: 300; }
