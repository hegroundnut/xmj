/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; position: relative; }

/* ===== Nav bar ===== */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-btn { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(0,0,0,0.04); display: flex; align-items: center; justify-content: center; }
.nav-btn-icon { font-size: 36rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }

/* ===== Watermark ===== */
.deco-text { padding: 8rpx 48rpx 0; position: relative; height: 72rpx; overflow: hidden; }
.wm { position: absolute; opacity: 0; }
.wm-profile { font-size: 48rpx; font-weight: 700; color: rgba(0,0,0,0.04); letter-spacing: 6rpx; top: 8rpx; left: -10rpx; text-shadow: 0 0 16rpx rgba(0,0,0,0.01); transform: rotate(-6deg); animation: wmFadeIn 0.7s ease-out 0.1s forwards; }
.wm-ali { font-size: 36rpx; font-weight: 300; color: rgba(0,0,0,0.03); letter-spacing: 6rpx; top: 20rpx; left: 180rpx; text-shadow: 0 0 12rpx rgba(0,0,0,0.01); transform: rotate(5deg); animation: wmFadeIn 0.7s ease-out 0.3s forwards; }

@keyframes wmFadeIn {
  from { opacity: 0; transform: translateY(24rpx) rotate(0deg); }
  to { opacity: 1; transform: translateY(0) rotate(-6deg); }
}

/* ===== Profile header ===== */
.profile-header { padding: 48rpx 48rpx 56rpx; display: flex; align-items: center; gap: 32rpx; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: #F0EFED; border: 4rpx solid rgba(0,0,0,0.04); display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
.avatar-img { width: 100%; height: 100%; }
.avatar-placeholder { font-size: 56rpx; color: rgba(0,0,0,0.2); }
.user-info { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 2rpx; margin-bottom: 6rpx; display: block; }
.user-id { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; letter-spacing: 1rpx; display: block; }
.edit-btn { padding: 12rpx 28rpx; border: 2rpx solid rgba(0,0,0,0.12); border-radius: 40rpx; font-size: 22rpx; color: #1A1A1A; background: transparent; letter-spacing: 2rpx; }

/* ===== Member card ===== */
.member-card { margin: 0 40rpx 48rpx; padding: 0; border-radius: 24rpx; background: #F0EBE0; border: 2rpx solid rgba(107,118,79,0.12); position: relative; overflow: hidden; min-height: 330rpx; }
.member-watermark { position: absolute; top: 45%; left: 50%; transform: translate(-50%,-50%); font-size: 104rpx; font-weight: 900; color: rgba(107,118,79,0.12); letter-spacing: 16rpx; white-space: nowrap; pointer-events: none; z-index: 1; text-shadow: 2rpx 2rpx 0 rgba(107,118,79,0.06); }
.member-deco { position: absolute; font-size: 18rpx; color: rgba(107,118,79,0.25); letter-spacing: 4rpx; font-weight: 400; z-index: 1; pointer-events: none; }
.member-content { position: relative; z-index: 2; padding: 44rpx 48rpx; }
.member-label { font-size: 18rpx; letter-spacing: 8rpx; color: #6B764F; text-transform: uppercase; margin-bottom: 16rpx; opacity: 0.5; font-weight: 400; display: block; }
.member-title { font-size: 36rpx; font-weight: 800; color: #6B764F; letter-spacing: 6rpx; margin-bottom: 8rpx; text-shadow: 2rpx 2rpx 0 rgba(107,118,79,0.12); display: block; }
.member-desc { font-size: 22rpx; color: #6B764F; font-weight: 300; margin-bottom: 32rpx; letter-spacing: 2rpx; opacity: 0.55; display: block; }
.member-btn { display: inline-block; padding: 16rpx 48rpx; background: #6B764F; color: #F0EBE0; font-size: 22rpx; border-radius: 40rpx; letter-spacing: 4rpx; font-weight: 500; }

/* ===== Stats row ===== */
.stats-row { display: flex; justify-content: space-around; padding: 0 40rpx; margin-bottom: 56rpx; }
.stat-item { text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 2rpx; display: block; }
.stat-label { font-size: 20rpx; color: rgba(0,0,0,0.3); margin-top: 6rpx; font-weight: 300; letter-spacing: 1rpx; display: block; }

/* ===== Menu sections ===== */
.menu-section { padding: 0 40rpx; margin-bottom: 40rpx; }
.menu-title { font-size: 22rpx; color: rgba(0,0,0,0.25); letter-spacing: 4rpx; margin-bottom: 20rpx; font-weight: 400; padding-left: 4rpx; display: block; }
.menu-list { background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 30rpx 32rpx; border-bottom: 2rpx solid rgba(0,0,0,0.04); }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 28rpx; width: 40rpx; text-align: center; }
.menu-text { flex: 1; font-size: 26rpx; color: #1A1A1A; letter-spacing: 1rpx; }
.menu-arrow { font-size: 28rpx; color: rgba(0,0,0,0.15); }
.menu-badge { font-size: 20rpx; color: #fff; background: #1A1A1A; padding: 4rpx 16rpx; border-radius: 20rpx; margin-right: 16rpx; font-weight: 400; }

/* ===== Account footer ===== */
.account-footer { padding: 0 40rpx; margin-bottom: 32rpx; }
.login-btn { width: 100%; padding: 28rpx; background: #1A1A1A; color: #fff; border-radius: 48rpx; font-size: 28rpx; font-weight: 400; letter-spacing: 4rpx; text-align: center; }
.logout-btn { width: 100%; padding: 28rpx; background: transparent; border: 2rpx solid rgba(0,0,0,0.08); color: rgba(0,0,0,0.4); border-radius: 48rpx; font-size: 28rpx; font-weight: 300; letter-spacing: 4rpx; text-align: center; }

.bottom-spacer { height: 80rpx; }

/* ===== QR Modal ===== */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 200; display: none; align-items: center; justify-content: center; }
.modal-overlay.show { display: flex; animation: modalFadeIn 0.3s ease; }
@keyframes modalFadeIn { from { opacity: 0; } to { opacity: 1; } }
.modal-card { background: #fff; border-radius: 32rpx; padding: 56rpx 48rpx 48rpx; width: 560rpx; text-align: center; position: relative; animation: modalSlideUp 0.35s ease; }
@keyframes modalSlideUp { from { opacity: 0; transform: translateY(40rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-close { position: absolute; top: 24rpx; right: 28rpx; width: 48rpx; height: 48rpx; border-radius: 50%; background: rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: rgba(0,0,0,0.3); line-height: 1; }
.modal-label { font-size: 18rpx; letter-spacing: 6rpx; color: #6B764F; text-transform: uppercase; opacity: 0.5; margin-bottom: 12rpx; display: block; }
.modal-title { font-size: 30rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 28rpx; letter-spacing: 2rpx; display: block; }
.modal-qr { width: 320rpx; height: 320rpx; margin: 0 auto 28rpx; border-radius: 20rpx; border: 2rpx solid rgba(0,0,0,0.06); overflow: hidden; background: #FAFAF8; }
.modal-qr-img { width: 100%; height: 100%; }
.modal-desc { font-size: 22rpx; color: rgba(0,0,0,0.4); line-height: 1.6; letter-spacing: 0.6rpx; font-weight: 300; white-space: pre-line; display: block; }
.modal-strong { color: #6B764F; font-weight: 500; }
.modal-hint { margin-top: 20rpx; font-size: 20rpx; color: rgba(0,0,0,0.25); letter-spacing: 1rpx; display: block; }
