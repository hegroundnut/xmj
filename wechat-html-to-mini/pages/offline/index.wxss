/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; position: relative; }

/* ===== LIST VIEW ===== */

/* Nav bar */
.nav-bar { display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 28rpx; }
.nav-back { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(0,0,0,0.04); display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 36rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 30rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 4rpx; }
.nav-spacer { width: 64rpx; }

/* Gradient header */
.page-header { padding: 16rpx 48rpx 32rpx; background: linear-gradient(180deg, #E8DDD3 0%, #EDE4DA 40%, #F3ECE5 70%, #fff 100%); }
.header-watermark { position: relative; height: 80rpx; overflow: hidden; margin-bottom: 4rpx; }
.wm { position: absolute; opacity: 0; }
.wm-1 { font-size: 56rpx; font-weight: 700; color: rgba(255,255,255,0.35); letter-spacing: 6rpx; transform: rotate(-5deg); top: 4rpx; left: -12rpx; animation: wmFadeIn 0.7s ease-out 0.1s forwards; }
.wm-2 { font-size: 40rpx; font-weight: 300; color: rgba(255,255,255,0.3); letter-spacing: 4rpx; transform: rotate(6deg); top: 28rpx; left: 180rpx; animation: wmFadeIn 0.7s ease-out 0.3s forwards; }
.wm-3 { font-size: 48rpx; font-weight: 700; color: rgba(255,255,255,0.25); letter-spacing: 4rpx; transform: rotate(-3deg); top: 12rpx; left: 380rpx; animation: wmFadeIn 0.7s ease-out 0.2s forwards; }

@keyframes wmFadeIn {
  from { opacity: 0; transform: translateY(24rpx) rotate(0deg); }
  to { opacity: 1; }
}

.page-title { font-size: 52rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 6rpx; display: block; }

/* Tabs */
.tabs { display: flex; padding: 0 40rpx; border-bottom: 2rpx solid rgba(0,0,0,0.06); }
.tab { flex: 1; text-align: center; padding: 20rpx 0; position: relative; display: flex; flex-direction: column; align-items: center; gap: 2rpx; }
.tab .en { font-size: 20rpx; font-weight: 600; letter-spacing: 3rpx; text-transform: lowercase; color: rgba(0,0,0,0.22); display: block; }
.tab .cn { font-size: 26rpx; font-weight: 400; color: rgba(0,0,0,0.35); letter-spacing: 1rpx; display: block; }
.tab.active .en { color: #1A1A1A; }
.tab.active .cn { color: #1A1A1A; font-weight: 500; }
.tab.active::after { content: ''; position: absolute; bottom: -2rpx; left: 50%; transform: translateX(-50%); width: 40rpx; height: 3rpx; background: #1A1A1A; }

/* States */
.state-box { display: flex; align-items: center; justify-content: center; padding: 200rpx 40rpx; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }

/* Offline list */
.offline-list { padding: 0 40rpx; display: flex; flex-direction: column; gap: 24rpx; margin-top: 24rpx; }
.offline-card { background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; padding: 32rpx; display: flex; gap: 28rpx; align-items: flex-start; }
.date-badge { flex-shrink: 0; width: 104rpx; height: 104rpx; border-radius: 16rpx; background: #1A1A1A; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rpx; }
.month { font-size: 18rpx; font-weight: 400; color: rgba(255,255,255,0.7); letter-spacing: 3rpx; text-transform: uppercase; display: block; }
.day { font-size: 36rpx; font-weight: 300; color: #fff; line-height: 1; display: block; }
.card-body { flex: 1; display: flex; flex-direction: column; gap: 12rpx; min-width: 0; }
.card-top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.card-title { font-size: 28rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 1rpx; line-height: 1.4; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }
.status-badge { flex-shrink: 0; font-size: 20rpx; font-weight: 400; padding: 6rpx 20rpx; border-radius: 24rpx; letter-spacing: 1rpx; }
.status-badge.open { background: rgba(26,26,26,0.06); color: #1A1A1A; }
.status-badge.full { background: rgba(0,0,0,0.03); color: rgba(0,0,0,0.25); }
.card-location { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; letter-spacing: 0.6rpx; display: block; }
.card-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 4rpx; }
.card-time { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; letter-spacing: 0.6rpx; display: block; }
.card-spots { font-size: 22rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 0.6rpx; display: block; }
.card-spots.muted { color: rgba(0,0,0,0.25); font-weight: 300; }
.bottom-spacer { height: 80rpx; }

/* ===== DETAIL VIEW ===== */

/* Event hero */
.event-hero { width: 100%; height: 400rpx; background: linear-gradient(135deg, #F5F4F2, #EBE9E6); position: relative; display: flex; align-items: flex-end; padding: 40rpx; }
.event-status { position: absolute; top: 32rpx; left: 32rpx; background: #1A1A1A; color: #fff; font-size: 20rpx; padding: 8rpx 28rpx; border-radius: 24rpx; letter-spacing: 2rpx; }
.event-date-badge { position: absolute; top: 32rpx; right: 32rpx; background: rgba(255,255,255,0.92); padding: 16rpx 28rpx; border-radius: 16rpx; text-align: center; }
.event-month { font-size: 20rpx; color: rgba(0,0,0,0.4); letter-spacing: 4rpx; font-weight: 300; display: block; }
.event-day { font-size: 44rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 2rpx; display: block; }
.event-title { font-size: 40rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 4rpx; display: block; margin-bottom: 8rpx; }
.event-sub { font-size: 24rpx; color: rgba(0,0,0,0.4); font-weight: 300; letter-spacing: 2rpx; display: block; }

/* Nav bar overlay */
.nav-bar-overlay { position: absolute; top: 0; left: 0; right: 0; display: flex; align-items: center; justify-content: space-between; padding-left: 40rpx; padding-right: 40rpx; z-index: 10; }
.nav-back-circle { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.9); }
.nav-back-icon-circle { font-size: 40rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-share-circle { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.9); }
.nav-share-icon-circle { font-size: 32rpx; color: #1A1A1A; }

/* Detail content */
.detail-content-area { height: calc(100vh - 400rpx); padding-bottom: 180rpx; }
.detail-section { padding: 40rpx; }
.detail-section.sm-top { padding-top: 0; }
.section-title { font-size: 22rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.3); display: block; margin-bottom: 28rpx; font-weight: 400; }
.detail-card { background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; padding: 32rpx; }

.detail-row { display: flex; align-items: flex-start; gap: 24rpx; padding: 16rpx 0; }
.d-icon { font-size: 32rpx; flex-shrink: 0; margin-top: 2rpx; }
.d-content { flex: 1; }
.d-label { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; display: block; margin-bottom: 4rpx; }
.d-value { font-size: 26rpx; color: #1A1A1A; font-weight: 400; letter-spacing: 1rpx; display: block; }

/* Outcomes */
.outcome-item { display: flex; align-items: flex-start; gap: 20rpx; margin-bottom: 8rpx; }
.outcome-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #1A1A1A; flex-shrink: 0; margin-top: 14rpx; }
.outcome-text { font-size: 26rpx; color: rgba(0,0,0,0.5); line-height: 1.6; font-weight: 300; }

/* Schedule */
.schedule-item { display: flex; gap: 32rpx; padding: 24rpx 0; border-bottom: 2rpx solid rgba(0,0,0,0.04); }
.schedule-item:last-child { border-bottom: none; }
.sched-time { font-size: 24rpx; color: #1A1A1A; font-weight: 400; white-space: nowrap; min-width: 120rpx; }
.sched-content { font-size: 26rpx; color: rgba(0,0,0,0.5); font-weight: 300; line-height: 1.4; }

/* Teacher */
.teacher-card { display: flex; align-items: center; gap: 28rpx; padding: 32rpx; background: #FAFAF8; border: 2rpx solid rgba(0,0,0,0.04); border-radius: 16rpx; }
.teacher-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #EBE9E6; flex-shrink: 0; }
.teacher-info { flex: 1; }
.teacher-name { font-size: 28rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 1rpx; display: block; }
.teacher-title { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; display: block; margin-top: 4rpx; }

/* Price */
.price-section { padding: 0 40rpx 32rpx; display: flex; align-items: center; justify-content: space-between; }
.price-info { display: flex; align-items: baseline; gap: 16rpx; }
.price-current { font-size: 48rpx; font-weight: 300; color: #1A1A1A; }
.price-original { font-size: 26rpx; color: rgba(0,0,0,0.25); text-decoration: line-through; font-weight: 300; }
.price-seats { font-size: 22rpx; color: rgba(0,0,0,0.35); font-weight: 300; }

/* Booking form */
.form-row { display: flex; align-items: center; gap: 24rpx; padding: 24rpx 0; border-bottom: 2rpx solid rgba(0,0,0,0.08); }
.form-label { font-size: 24rpx; color: rgba(0,0,0,0.4); white-space: nowrap; }
.form-input { flex: 1; border: none; outline: none; font-size: 26rpx; color: #1A1A1A; background: transparent; }
.form-tip { font-size: 22rpx; color: rgba(0,0,0,0.3); display: block; margin-top: 20rpx; font-weight: 300; }
.qr-section { margin-top: 24rpx; }
.qr-label { font-size: 24rpx; color: rgba(0,0,0,0.4); display: block; margin-bottom: 20rpx; }
.qr-img { width: 200rpx; height: 200rpx; background: #F0EFED; border-radius: 16rpx; display: block; }

/* Bottom bar */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 160rpx; padding: 0 40rpx 56rpx; display: flex; align-items: center; background: rgba(255,255,255,0.95); border-top: 2rpx solid rgba(0,0,0,0.04); z-index: 100; }
.enroll-btn { flex: 1; padding: 28rpx; background: #1A1A1A; color: #fff; border: none; border-radius: 48rpx; font-size: 28rpx; font-weight: 400; letter-spacing: 4rpx; line-height: 1.2; }
