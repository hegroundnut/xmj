.offline-page { background: #fff; min-height: 100vh; padding-bottom: 140rpx; }

.event-hero { width: 100%; height: 340rpx; background: linear-gradient(135deg, #F5F4F2, #EBE9E6); position: relative; display: flex; align-items: flex-end; padding: 32rpx; }
.event-date-badge { position: absolute; top: 24rpx; right: 24rpx; background: rgba(255,255,255,0.92); padding: 14rpx 24rpx; border-radius: 12rpx; text-align: center; }
.month { font-size: 18rpx; color: rgba(0,0,0,0.4); letter-spacing: 4rpx; display: block; }
.day { font-size: 40rpx; font-weight: 300; color: #1A1A1A; display: block; }
.event-status { position: absolute; top: 24rpx; left: 24rpx; background: #1A1A1A; color: #fff; font-size: 20rpx; padding: 8rpx 24rpx; border-radius: 24rpx; letter-spacing: 2rpx; }
.event-title { font-size: 38rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 4rpx; display: block; margin-bottom: 6rpx; }
.event-sub { font-size: 24rpx; color: rgba(0,0,0,0.4); display: block; }

.detail-section { padding: 32rpx 30rpx; }
.detail-section:first-of-type { padding-top: 32rpx; }
.section-label { font-size: 22rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.3); display: block; margin-bottom: 24rpx; }
.detail-card { background: #FAFAF8; border: 1px solid rgba(0,0,0,0.04); border-radius: 12rpx; padding: 24rpx; }
.detail-row { display: flex; align-items: flex-start; gap: 20rpx; padding: 14rpx 0; }
.d-icon { font-size: 30rpx; flex-shrink: 0; margin-top: 2rpx; }
.d-content { flex: 1; }
.d-label { font-size: 22rpx; color: rgba(0,0,0,0.3); display: block; margin-bottom: 4rpx; }
.d-value { font-size: 26rpx; color: #1A1A1A; display: block; }

.outcome-item { display: flex; align-items: flex-start; gap: 16rpx; padding: 8rpx 0; }
.outcome-dot { font-size: 24rpx; color: #1A1A1A; margin-top: -2rpx; }
.outcome-text { font-size: 26rpx; color: rgba(0,0,0,0.5); line-height: 1.6; }

.schedule-item { display: flex; gap: 28rpx; padding: 20rpx 0; border-bottom: 1px solid rgba(0,0,0,0.04); }
.schedule-item:last-child { border-bottom: none; }
.schedule-time { font-size: 24rpx; color: #1A1A1A; font-weight: 500; white-space: nowrap; min-width: 120rpx; }
.schedule-content { font-size: 26rpx; color: rgba(0,0,0,0.5); }

.teacher-card { display: flex; align-items: center; gap: 24rpx; padding: 28rpx; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.04); border-radius: 12rpx; }
.teacher-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: #EBE9E6; }
.teacher-info { flex: 1; }
.teacher-name { font-size: 28rpx; color: #1A1A1A; display: block; }
.teacher-title { font-size: 22rpx; color: rgba(0,0,0,0.3); display: block; margin-top: 4rpx; }

.price-section { padding: 0 30rpx 32rpx; display: flex; align-items: center; justify-content: space-between; }
.price-info { display: flex; align-items: baseline; gap: 16rpx; }
.price-current { font-size: 44rpx; font-weight: 300; color: #1A1A1A; }
.price-original { font-size: 24rpx; color: rgba(0,0,0,0.25); text-decoration: line-through; }
.price-seats { font-size: 22rpx; color: rgba(0,0,0,0.35); }

.form-row { display: flex; align-items: center; gap: 24rpx; padding: 20rpx 0; border-bottom: 1px solid rgba(0,0,0,0.08); }
.form-row:last-child { border-bottom: none; }
.form-label { font-size: 24rpx; color: rgba(0,0,0,0.4); white-space: nowrap; }
.form-input { flex: 1; border: none; outline: none; font-size: 26rpx; color: #1A1A1A; background: transparent; }

.qr-img { width: 180rpx; height: 180rpx; background: #F0EFED; border-radius: 12rpx; display: block; margin-bottom: 16rpx; }
.qr-tip { font-size: 22rpx; color: rgba(0,0,0,0.3); }

.divider { height: 1px; background: rgba(0,0,0,0.04); margin: 0 30rpx; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 110rpx; padding: 0 30rpx; display: flex; align-items: center; background: rgba(255,255,255,0.95); border-top: 1px solid rgba(0,0,0,0.04); z-index: 100; }
.enroll-btn { flex: 1; padding: 28rpx; background: #1A1A1A; color: #fff; border: none; border-radius: 48rpx; font-size: 28rpx; letter-spacing: 4rpx; }
.error-box { text-align: center; padding: 200rpx 40rpx; color: #999; font-size: 28rpx; }
