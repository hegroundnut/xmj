<view class="page">
  <!-- Hero (behind nav) -->
  <view class="course-hero" wx:if="{{course}}">
    <image src="{{course.cover || ''}}" mode="aspectFill" class="hero-bg" wx:if="{{course.cover}}"/>
    <view class="hero-placeholder" wx:else/>
    <view class="hero-overlay"/>
    <text class="hero-tag">{{course.category_name || '入门必修'}}</text>
    <view class="hero-play" bindtap="onPlay" wx:if="{{course.video_url}}">
      <text class="hero-play-icon">▶</text>
    </view>
  </view>

  <!-- Nav bar (over hero) -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight + 10}}px;" wx:if="{{course}}">
    <view class="nav-back" bindtap="onBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <view class="nav-share">
      <text class="nav-share-icon">◎</text>
    </view>
  </view>

  <!-- Loading / Error -->
  <view class="state-box" wx:if="{{loading}}"><text class="state-text">加载中...</text></view>
  <view class="state-box" wx:elif="{{error}}" bindtap="loadData"><text class="state-text">加载失败，点击重试</text></view>
  <view class="state-box" wx:elif="{{!course}}"><text class="state-text">课程不存在</text></view>

  <scroll-view scroll-y class="content-area" wx:if="{{course}}">
    <!-- Info section -->
    <view class="info-section">
      <text class="info-title">{{course.title}}</text>
      <text class="info-sub">{{course.description || course.desc || '系统掌握洗眉核心技术'}}</text>
      <view class="info-row">
        <text class="info-badge">📹 {{course.lesson_count || '12'}}课时</text>
        <text class="info-badge">👤 {{course.student_count || '1286'}}人已学</text>
        <text class="info-badge">⭐ {{course.rating || '4.9'}}分</text>
      </view>
      <view class="price-section">
        <view class="price-top-row">
          <view class="price-left">
            <text class="price-current">¥{{course.price || '9.9'}}</text>
            <text class="price-label">试听价</text>
          </view>
          <text class="member-badge" wx:if="{{course.is_free_for_member === 1}}">会员免费</text>
          <text class="price-original" wx:if="{{course.original_price}}">¥{{course.original_price}}</text>
        </view>
        <text class="member-notice" wx:if="{{!isMember}}">开通会员可免费观看全部课程</text>
      </view>
    </view>

    <view class="divider"/>

    <!-- Teacher -->
    <view class="teacher-section">
      <view class="teacher-card">
        <image src="{{course.teacher_avatar || '/static/images/def_avatar.png'}}" class="teacher-avatar"/>
        <view class="teacher-info">
          <text class="teacher-name">{{course.teacher_name || '王美学老师'}}</text>
          <text class="teacher-title">{{course.teacher_title || '资深洗眉专家 · 高级讲师'}}</text>
          <text class="teacher-stats">授课 {{course.teacher_course_count || '36'}} 门 · 学员 {{course.teacher_student_count || '5000'}}+</text>
        </view>
      </view>
    </view>

    <view class="divider"/>

    <!-- Curriculum -->
    <view class="curriculum-section" wx:if="{{course.lessons && course.lessons.length}}">
      <text class="section-title">课程大纲 · {{course.lessons.length}}课时</text>
      <view class="lesson-item" wx:for="{{course.lessons}}" wx:key="id">
        <text class="lesson-num">{{index + 1}}</text>
        <view class="lesson-info">
          <text class="lesson-name">{{item.title || item.name}}</text>
          <text class="lesson-duration" wx:if="{{item.duration}}">{{item.duration}}分钟</text>
        </view>
        <text class="lesson-free" wx:if="{{item.is_free}}">试看</text>
        <text class="lesson-lock" wx:else>🔒</text>
      </view>
    </view>

    <view class="divider"/>

    <!-- Reviews -->
    <view class="review-section" wx:if="{{course.reviews && course.reviews.length}}">
      <text class="section-title">学员评价</text>
      <view class="review-item" wx:for="{{course.reviews}}" wx:key="id">
        <view class="review-header">
          <image src="{{item.avatar || '/static/images/def_avatar.png'}}" class="review-avatar"/>
          <text class="review-name">{{item.nickname || '学员'}}</text>
          <text class="review-stars">★★★★★</text>
        </view>
        <text class="review-text">{{item.content}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Bottom bar -->
  <view class="bottom-bar" wx:if="{{course}}">
    <view class="bottom-action {{course.is_favorited ? 'fav-active' : ''}}" bindtap="onToggleFav">
      <text class="action-icon">{{course.is_favorited ? '★' : '🔖'}}</text>
      <text class="action-label">{{course.is_favorited ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="bottom-action">
      <text class="action-icon">◎</text>
      <text class="action-label">分享</text>
    </view>
    <button class="buy-btn" bindtap="onBuy">
      {{isMember || course.is_free_for_member === 1 ? '开始学习 · 会员免费' : '¥' + (course.price || '9.9') + ' 试听 · 会员免费'}}
    </button>
  </view>
</view>
