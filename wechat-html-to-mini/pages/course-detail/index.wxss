/* ===== Page ===== */
.page { background: #fff; min-height: 100vh; position: relative; }

/* ===== Hero ===== */
.course-hero { width: 100%; height: 440rpx; background: #F0EFED; position: relative; }
.hero-bg { width: 100%; height: 100%; }
.hero-placeholder { width: 100%; height: 100%; background: #F0EFED; }
.hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 160rpx; background: linear-gradient(transparent, rgba(255,255,255,0.8)); }
.hero-tag { position: absolute; top: 32rpx; left: 32rpx; background: #1A1A1A; color: #fff; font-size: 20rpx; padding: 8rpx 28rpx; border-radius: 24rpx; letter-spacing: 2rpx; }
.hero-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 96rpx; height: 96rpx; border-radius: 50%; background: rgba(255,255,255,0.9); display: flex; align-items: center; justify-content: center; }
.hero-play-icon { font-size: 40rpx; color: #1A1A1A; margin-left: 4rpx; }

/* ===== Nav Bar (absolute over hero) ===== */
.nav-bar { position: absolute; top: 0; left: 0; right: 0; display: flex; align-items: center; justify-content: space-between; padding: 100rpx 40rpx 28rpx; z-index: 10; }
.nav-back { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.9); }
.nav-back-icon { font-size: 40rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-share { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.9); }
.nav-share-icon { font-size: 32rpx; color: #1A1A1A; }

/* ===== Content area ===== */
.content-area { padding-bottom: 180rpx; }

/* ===== Info section ===== */
.info-section { padding: 40rpx; }
.info-title { font-size: 40rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 4rpx; line-height: 1.4; display: block; margin-bottom: 20rpx; }
.info-sub { font-size: 24rpx; color: rgba(0,0,0,0.35); line-height: 1.6; font-weight: 300; display: block; margin-bottom: 32rpx; }
.info-row { display: flex; gap: 40rpx; margin-bottom: 32rpx; }
.info-badge { font-size: 22rpx; color: rgba(0,0,0,0.4); font-weight: 300; }

/* Price section */
.price-section { }
.price-top-row { display: flex; align-items: center; gap: 20rpx; }
.price-left { display: flex; flex-direction: column; align-items: flex-start; }
.price-current { font-size: 52rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 2rpx; }
.price-label { font-size: 22rpx; color: rgba(0,0,0,0.35); font-weight: 300; margin-top: 4rpx; }
.member-badge { font-size: 20rpx; color: #fff; background: #1A1A1A; padding: 8rpx 24rpx; border-radius: 24rpx; letter-spacing: 1rpx; }
.price-original { font-size: 28rpx; color: rgba(0,0,0,0.25); text-decoration: line-through; font-weight: 300; }
.member-notice { display: inline-block; border: 1px solid rgba(0,0,0,0.08); border-radius: 40rpx; padding: 12rpx 28rpx; font-size: 22rpx; color: rgba(0,0,0,0.4); font-weight: 300; margin-top: 20rpx; }

/* ===== Divider ===== */
.divider { height: 1px; background: rgba(0,0,0,0.04); margin: 0 40rpx; }

/* ===== Teacher ===== */
.teacher-section { padding: 40rpx; }
.teacher-card { display: flex; align-items: center; gap: 28rpx; }
.teacher-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #F0EFED; flex-shrink: 0; }
.teacher-info { flex: 1; }
.teacher-name { font-size: 28rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 1rpx; display: block; }
.teacher-title { font-size: 22rpx; color: rgba(0,0,0,0.3); font-weight: 300; display: block; margin-top: 4rpx; }
.teacher-stats { font-size: 22rpx; color: rgba(0,0,0,0.25); font-weight: 300; display: block; margin-top: 8rpx; }

/* ===== Curriculum ===== */
.curriculum-section { padding: 40rpx; }
.section-title { font-size: 22rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.3); display: block; margin-bottom: 32rpx; font-weight: 400; }
.lesson-item { display: flex; align-items: center; padding: 26rpx 0; border-bottom: 1px solid rgba(0,0,0,0.04); gap: 28rpx; }
.lesson-item:last-child { border-bottom: none; }
.lesson-num { width: 48rpx; height: 48rpx; border-radius: 50%; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: rgba(0,0,0,0.35); flex-shrink: 0; font-weight: 300; }
.lesson-info { flex: 1; }
.lesson-name { font-size: 26rpx; font-weight: 400; color: #1A1A1A; letter-spacing: 1rpx; display: block; }
.lesson-duration { font-size: 22rpx; color: rgba(0,0,0,0.25); font-weight: 300; display: block; margin-top: 4rpx; }
.lesson-free { font-size: 20rpx; color: #1A1A1A; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.06); padding: 4rpx 20rpx; border-radius: 20rpx; letter-spacing: 1rpx; }
.lesson-lock { font-size: 22rpx; color: rgba(0,0,0,0.25); }

/* ===== Reviews ===== */
.review-section { padding: 40rpx; }
.review-item { padding: 28rpx; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.04); border-radius: 16rpx; margin-bottom: 20rpx; }
.review-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 16rpx; }
.review-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: #EBE9E6; flex-shrink: 0; }
.review-name { font-size: 24rpx; font-weight: 400; color: #1A1A1A; flex: 1; }
.review-stars { font-size: 20rpx; color: rgba(0,0,0,0.3); letter-spacing: 4rpx; }
.review-text { font-size: 24rpx; color: rgba(0,0,0,0.45); line-height: 1.6; font-weight: 300; display: block; }

/* ===== Bottom bar ===== */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 160rpx; padding: 0 40rpx 56rpx; display: flex; align-items: center; gap: 24rpx; background: rgba(255,255,255,0.95); border-top: 1px solid rgba(0,0,0,0.04); z-index: 100; }
.bottom-action { display: flex; flex-direction: column; align-items: center; gap: 4rpx; width: 100rpx; }
.action-icon { font-size: 32rpx; }
.action-label { font-size: 20rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
.buy-btn { flex: 1; padding: 28rpx; background: #1A1A1A; color: #fff; border: none; border-radius: 48rpx; font-size: 28rpx; font-weight: 400; letter-spacing: 2rpx; line-height: 1.2; }

/* ===== State ===== */
.state-box { display: flex; align-items: center; justify-content: center; height: 100vh; }
.state-text { font-size: 28rpx; color: rgba(0,0,0,0.3); font-weight: 300; }
