.course-detail-page { background: #fff; min-height: 100vh; padding-bottom: 140rpx; }
.course-hero { width: 100%; height: 440rpx; background: #F0EFED; position: relative; }
.hero-cover { width: 100%; height: 100%; }
.hero-video { width: 100%; height: 100%; }
.hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 120rpx; background: linear-gradient(transparent, rgba(255,255,255,0.8)); }
.hero-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 96rpx; height: 96rpx; border-radius: 50%; background: rgba(255,255,255,0.9); display: flex; align-items: center; justify-content: center; }
.play-icon { font-size: 36rpx; color: #1A1A1A; margin-left: 4rpx; }
.hero-tag { position: absolute; top: 24rpx; left: 24rpx; background: #1A1A1A; color: #fff; font-size: 20rpx; padding: 8rpx 24rpx; border-radius: 24rpx; letter-spacing: 2rpx; }

.info-section { padding: 32rpx 30rpx; }
.info-title { font-size: 40rpx; font-weight: 300; color: #1A1A1A; letter-spacing: 4rpx; display: block; line-height: 1.4; margin-bottom: 16rpx; }
.info-sub { font-size: 24rpx; color: rgba(0,0,0,0.35); line-height: 1.6; display: block; margin-bottom: 24rpx; }
.info-row { display: flex; gap: 32rpx; margin-bottom: 28rpx; }
.info-badge { font-size: 22rpx; color: rgba(0,0,0,0.4); }

.price-section { }
.price-row { display: flex; align-items: center; gap: 20rpx; }
.price-main { display: flex; flex-direction: column; align-items: flex-start; }
.price-current { font-size: 44rpx; font-weight: 300; color: #1A1A1A; }
.price-label { font-size: 22rpx; color: rgba(0,0,0,0.35); margin-top: 2rpx; }
.member-badge { font-size: 20rpx; color: #fff; background: #1A1A1A; padding: 8rpx 24rpx; border-radius: 24rpx; }
.price-original { font-size: 24rpx; color: rgba(0,0,0,0.25); text-decoration: line-through; }
.member-notice { display: inline-block; margin-top: 16rpx; border: 1px solid rgba(0,0,0,0.08); border-radius: 40rpx; padding: 12rpx 28rpx; font-size: 22rpx; color: rgba(0,0,0,0.4); }

.divider { height: 1px; background: rgba(0,0,0,0.04); margin: 0 30rpx; }

.teacher-section { padding: 32rpx 30rpx; }
.teacher-card { display: flex; align-items: center; gap: 24rpx; }
.teacher-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: #F0EFED; }
.teacher-info { flex: 1; }
.teacher-name { font-size: 28rpx; color: #1A1A1A; display: block; }
.teacher-title { font-size: 22rpx; color: rgba(0,0,0,0.3); display: block; margin-top: 4rpx; }
.teacher-stats { font-size: 22rpx; color: rgba(0,0,0,0.25); display: block; margin-top: 6rpx; }

.curriculum-section { padding: 32rpx 30rpx; }
.section-label { font-size: 22rpx; letter-spacing: 6rpx; color: rgba(0,0,0,0.3); display: block; margin-bottom: 24rpx; }
.lesson-item { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1px solid rgba(0,0,0,0.04); gap: 24rpx; }
.lesson-item:last-child { border-bottom: none; }
.lesson-num { width: 48rpx; height: 48rpx; border-radius: 50%; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: rgba(0,0,0,0.35); flex-shrink: 0; }
.lesson-info { flex: 1; }
.lesson-name { font-size: 26rpx; color: #1A1A1A; display: block; }
.lesson-duration { font-size: 22rpx; color: rgba(0,0,0,0.25); display: block; margin-top: 4rpx; }
.lesson-free { font-size: 20rpx; color: #1A1A1A; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.06); padding: 4rpx 20rpx; border-radius: 20rpx; }
.lesson-lock { font-size: 24rpx; }

.review-section { padding: 32rpx 30rpx; }
.review-item { padding: 24rpx; background: #FAFAF8; border: 1px solid rgba(0,0,0,0.04); border-radius: 12rpx; margin-bottom: 16rpx; }
.review-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.review-avatar { width: 52rpx; height: 52rpx; border-radius: 50%; background: #EBE9E6; }
.review-name { font-size: 24rpx; color: #1A1A1A; flex: 1; }
.review-stars { font-size: 20rpx; color: rgba(0,0,0,0.3); letter-spacing: 4rpx; }
.review-text { font-size: 24rpx; color: rgba(0,0,0,0.45); line-height: 1.6; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 110rpx; padding: 0 30rpx; display: flex; align-items: center; gap: 20rpx; background: rgba(255,255,255,0.95); border-top: 1px solid rgba(0,0,0,0.04); z-index: 100; }
.bottom-action { display: flex; flex-direction: column; align-items: center; gap: 4rpx; width: 80rpx; font-size: 32rpx; }
.action-label { font-size: 20rpx; color: rgba(0,0,0,0.3); }
.buy-btn { flex: 1; padding: 28rpx; background: #1A1A1A; color: #fff; border: none; border-radius: 48rpx; font-size: 28rpx; letter-spacing: 2rpx; }
.error-box { text-align: center; padding: 200rpx 40rpx; color: #999; font-size: 28rpx; }
